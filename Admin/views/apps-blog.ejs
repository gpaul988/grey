<%- contentFor('html_attribute') %>
<%- contentFor('extra_css') %>
<%- contentFor('content') %>

<%- include('./partials/page-title', { title: title, subtitle: 'Content' }) %>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h4 class="card-title mb-0">Blog Posts <span class="badge bg-primary-subtle text-primary ms-1"><%= posts.length %></span></h4>
                <button class="btn btn-sm btn-primary" id="btnNew"><i class="ti ti-plus"></i> New Post</button>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-centered mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr><th>Title</th><th>Author</th><th>Tags</th><th>Status</th><th>Published</th><th class="text-end">Action</th></tr>
                    </thead>
                    <tbody>
                        <% if (!posts.length) { %><tr><td colspan="6" class="text-center text-muted py-4">No posts yet.</td></tr><% } %>
                        <% posts.forEach((p) => { let tags=[]; try { tags = JSON.parse(p.tags||'[]'); } catch(e){} %>
                        <tr>
                            <td><div class="fw-medium"><%= p.title %></div><small class="text-muted">/<%= p.slug %></small></td>
                            <td><%= p.author %></td>
                            <td><% tags.slice(0,3).forEach(t=>{ %><span class="badge bg-light text-dark me-1"><%= t %></span><% }) %></td>
                            <td><span class="badge bg-<%= p.status==='published'?'success':'secondary' %>-subtle text-<%= p.status==='published'?'success':'secondary' %> text-capitalize"><%= p.status %></span></td>
                            <td class="text-muted fs-13"><%= p.published_at || '—' %></td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-soft-primary btn-edit"
                                    data-id="<%= p.id %>" data-title="<%= p.title %>" data-author="<%= p.author %>" data-cover="<%= p.cover||'' %>"
                                    data-status="<%= p.status %>" data-tags="<%= tags.join(', ') %>" data-published="<%= p.published_at||'' %>"
                                    data-excerpt="<%- (p.excerpt||'').replace(/"/g,'&quot;') %>" data-body="<%- (p.body||'').replace(/"/g,'&quot;') %>"><i class="ti ti-edit"></i></button>
                                <button class="btn btn-sm btn-soft-danger btn-del" data-id="<%= p.id %>"><i class="ti ti-trash"></i></button>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="bModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title" id="mTitle">New Post</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <input type="hidden" id="f_id">
                <div class="row g-3">
                    <div class="col-md-8"><label class="form-label">Title *</label><input id="f_title" class="form-control"></div>
                    <div class="col-md-4"><label class="form-label">Status</label><select id="f_status" class="form-select"><option value="draft">Draft</option><option value="published">Published</option></select></div>
                    <div class="col-md-6"><label class="form-label">Author</label><input id="f_author" class="form-control" value="Grey InfoTech"></div>
                    <div class="col-md-6"><label class="form-label">Publish date</label><input id="f_published" type="date" class="form-control"></div>
                    <div class="col-12"><label class="form-label">Cover image URL</label><input id="f_cover" class="form-control"></div>
                    <div class="col-12"><label class="form-label">Tags (comma separated)</label><input id="f_tags" class="form-control"></div>
                    <div class="col-12"><label class="form-label">Excerpt</label><textarea id="f_excerpt" class="form-control" rows="2"></textarea></div>
                    <div class="col-12"><label class="form-label">Body</label><textarea id="f_body" class="form-control" rows="6"></textarea></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-light" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" id="btnSave">Save</button></div>
        </div>
    </div>
</div>

<%- contentFor('extra_javascript') %>
<%- include('./partials/admin-api-helper') %>
<script>
(function () {
    const modal = new bootstrap.Modal('#bModal');
    const F = (id) => document.getElementById(id);
    function open(d) {
        F('f_id').value = d.id || ''; F('mTitle').textContent = d.id ? 'Edit Post' : 'New Post';
        F('f_title').value = d.title || ''; F('f_author').value = d.author || 'Grey InfoTech';
        F('f_status').value = d.status || 'draft'; F('f_published').value = d.published || '';
        F('f_cover').value = d.cover || ''; F('f_tags').value = d.tags || '';
        F('f_excerpt').value = d.excerpt || ''; F('f_body').value = d.body || '';
        modal.show();
    }
    F('btnNew').addEventListener('click', () => open({}));
    document.querySelectorAll('.btn-edit').forEach(b => b.addEventListener('click', () => open(b.dataset)));
    F('btnSave').addEventListener('click', async () => {
        const id = F('f_id').value;
        const payload = {
            title: F('f_title').value.trim(), author: F('f_author').value.trim(), status: F('f_status').value,
            published_at: F('f_published').value || '', cover: F('f_cover').value.trim(),
            tags: F('f_tags').value, excerpt: F('f_excerpt').value.trim(), body: F('f_body').value.trim(),
        };
        if (!payload.title) return AdminAPI.toast('Title required', true);
        const r = id ? await AdminAPI.patch('/blog/' + id, payload) : await AdminAPI.post('/blog', payload);
        if (r.ok) { AdminAPI.toast(r.message); location.reload(); } else AdminAPI.toast(r.message, true);
    });
    document.querySelectorAll('.btn-del').forEach(b => b.addEventListener('click', async () => {
        if (!confirm('Delete this post?')) return;
        const r = await AdminAPI.del('/blog/' + b.dataset.id);
        if (r.ok) { AdminAPI.toast('Deleted'); b.closest('tr').remove(); } else AdminAPI.toast(r.message, true);
    }));
})();
</script>
