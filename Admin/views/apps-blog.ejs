<%- contentFor('html_attribute') %>
<%- contentFor('extra_css') %>
<%- contentFor('content') %>

<%- include('./partials/page-title', { title: title, subtitle: 'Content' }) %>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h4 class="card-title mb-0">Blog Posts <span class="badge bg-primary-subtle text-primary ms-1"><%= posts.length %></span></h4>
                <button class="btn btn-sm btn-primary" id="btnNew"><i class="ti ti-plus"></i> New Post</button>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-centered mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr><th>Title</th><th>Author</th><th>Read time</th><th>Tags</th><th>Status</th><th>Published</th><th class="text-end">Action</th></tr>
                    </thead>
                    <tbody>
                        <% if (!posts.length) { %><tr><td colspan="7" class="text-center text-muted py-4">No posts yet.</td></tr><% } %>
                        <% posts.forEach((p) => {
                            let tags=[], sections=[];
                            try { tags = JSON.parse(p.tags||'[]'); } catch(e){}
                            try { sections = JSON.parse(p.sections||'[]'); } catch(e){}
                        %>
                        <tr>
                            <td>
                                <div class="fw-medium"><%= p.title %></div>
                                <small class="text-muted">/<%= p.slug %></small>
                                <% if (sections.length) { %><small class="text-muted ms-2">· <%= sections.length %> section<%= sections.length!==1?'s':'' %></small><% } %>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <% if (p.author_avatar) { %><img src="<%= p.author_avatar %>" class="rounded-circle" width="24" height="24" style="object-fit:cover"><% } %>
                                    <span><%= p.author %></span>
                                </div>
                                <% if (p.author_role) { %><small class="text-muted"><%= p.author_role %></small><% } %>
                            </td>
                            <td class="text-muted fs-13"><%= p.read_time || '—' %></td>
                            <td><% tags.slice(0,3).forEach(t=>{ %><span class="badge bg-light text-dark me-1"><%= t %></span><% }) %></td>
                            <td><span class="badge bg-<%= p.status==='published'?'success':'secondary' %>-subtle text-<%= p.status==='published'?'success':'secondary' %> text-capitalize"><%= p.status %></span></td>
                            <td class="text-muted fs-13"><%= p.published_at || '—' %></td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-soft-primary btn-edit"
                                    data-id="<%= p.id %>"
                                    data-title="<%= p.title %>"
                                    data-author="<%= p.author %>"
                                    data-author-role="<%= p.author_role||'' %>"
                                    data-author-avatar="<%= p.author_avatar||'' %>"
                                    data-cover="<%= p.cover||'' %>"
                                    data-hero-image="<%= p.hero_image||'' %>"
                                    data-read-time="<%= p.read_time||'' %>"
                                    data-status="<%= p.status %>"
                                    data-tags="<%= tags.join(', ') %>"
                                    data-published="<%= p.published_at||'' %>"
                                    data-excerpt="<%- (p.excerpt||'').replace(/"/g,'&quot;') %>"
                                    data-body="<%- (p.body||'').replace(/"/g,'&quot;') %>"
                                    data-sections="<%- JSON.stringify(sections).replace(/"/g,'&quot;') %>"><i class="ti ti-edit"></i></button>
                                <button class="btn btn-sm btn-soft-danger btn-del" data-id="<%= p.id %>"><i class="ti ti-trash"></i></button>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Blog Post Modal -->
<div class="modal fade" id="bModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header border-bottom">
                <h5 class="modal-title" id="mTitle">New Post</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="f_id">

                <!-- Nav tabs -->
                <ul class="nav nav-tabs mb-4" id="blogTabs">
                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-basic" type="button">Basic</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-author" type="button">Author</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-content" type="button">Content</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-sections" type="button">Sections <span class="badge bg-primary-subtle text-primary ms-1" id="sectionCount">0</span></button></li>
                </ul>

                <div class="tab-content" id="blogTabContent">

                    <!-- Basic Tab -->
                    <div class="tab-pane fade show active" id="tab-basic">
                        <div class="row g-3">
                            <div class="col-md-8"><label class="form-label fw-medium">Title <span class="text-danger">*</span></label><input id="f_title" class="form-control" placeholder="Post title"></div>
                            <div class="col-md-4"><label class="form-label fw-medium">Status</label><select id="f_status" class="form-select"><option value="draft">Draft</option><option value="published">Published</option></select></div>
                            <div class="col-md-4"><label class="form-label fw-medium">Publish date</label><input id="f_published" type="date" class="form-control"></div>
                            <div class="col-md-4"><label class="form-label fw-medium">Read time</label><input id="f_read_time" class="form-control" placeholder="e.g. 6 min read"></div>
                            <div class="col-md-4"><label class="form-label fw-medium">Tags <span class="text-muted">(comma separated)</span></label><input id="f_tags" class="form-control" placeholder="AI, Product, Strategy"></div>
                            <div class="col-md-6"><label class="form-label fw-medium">Cover image URL <span class="text-muted">(listing thumbnail)</span></label><input id="f_cover" class="form-control" placeholder="/assets/..."></div>
                            <div class="col-md-6"><label class="form-label fw-medium">Hero image URL <span class="text-muted">(post page banner)</span></label><input id="f_hero_image" class="form-control" placeholder="/assets/..."></div>
                            <div class="col-12"><label class="form-label fw-medium">Excerpt</label><textarea id="f_excerpt" class="form-control" rows="3" placeholder="Brief summary shown on listing and social previews."></textarea></div>
                        </div>
                    </div>

                    <!-- Author Tab -->
                    <div class="tab-pane fade" id="tab-author">
                        <div class="row g-3">
                            <div class="col-md-6"><label class="form-label fw-medium">Author name</label><input id="f_author" class="form-control" value="Grey InfoTech" placeholder="Full name"></div>
                            <div class="col-md-6"><label class="form-label fw-medium">Author role / title</label><input id="f_author_role" class="form-control" placeholder="e.g. Head of Product, Grey InfoTech"></div>
                            <div class="col-12"><label class="form-label fw-medium">Author avatar URL</label><input id="f_author_avatar" class="form-control" placeholder="/assets/team/...">
                                <div class="mt-2" id="avatarPreviewWrap" style="display:none">
                                    <img id="avatarPreview" src="" alt="Avatar preview" class="rounded-circle" width="48" height="48" style="object-fit:cover; border:2px solid #dee2e6;">
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="alert alert-info py-2 mb-0 fs-13">
                                    <i class="ti ti-info-circle me-1"></i>
                                    The author name, role and avatar appear on the single post page and in the post meta row.
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Content Tab -->
                    <div class="tab-pane fade" id="tab-content">
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="alert alert-light py-2 mb-2 fs-13">
                                    <i class="ti ti-bulb me-1 text-warning"></i>
                                    Use <code>**Heading text**</code> on its own line to create a section heading (also appears in the Table of Contents on the post page).
                                </div>
                                <label class="form-label fw-medium">Body</label>
                                <textarea id="f_body" class="form-control" rows="18" placeholder="Write the main article body here. Use **Heading** on its own line to create section headings.&#10;&#10;Paragraphs are separated by a blank line.&#10;&#10;Use:&#10;- item one&#10;- item two&#10;for bullet lists."></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Sections Tab -->
                    <div class="tab-pane fade" id="tab-sections">
                        <div class="mb-3 d-flex justify-content-between align-items-center">
                            <div>
                                <p class="mb-0 fs-13 text-muted">Sections appear <strong>after</strong> the body as structured content blocks — each with a heading, text, and an optional image. Mirrors the Lightflows single-post layout.</p>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-primary ms-3" id="btnAddSection"><i class="ti ti-plus"></i> Add section</button>
                        </div>
                        <div id="sectionsContainer" class="d-flex flex-column gap-3"></div>
                        <p class="text-muted fs-13 mt-3" id="noSectionsMsg">No sections yet — click "Add section" to add the first one.</p>
                    </div>

                </div><!-- /tab-content -->
            </div>
            <div class="modal-footer border-top">
                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="btnSave"><i class="ti ti-device-floppy me-1"></i>Save post</button>
            </div>
        </div>
    </div>
</div>

<%- contentFor('extra_javascript') %>
<%- include('./partials/admin-api-helper') %>
<script>
(function () {
    const modal = new bootstrap.Modal('#bModal');
    const F = (id) => document.getElementById(id);
    let sections = [];

    /* ── avatar preview ── */
    F('f_author_avatar').addEventListener('input', function() {
        const wrap = F('avatarPreviewWrap');
        if (this.value.trim()) { F('avatarPreview').src = this.value.trim(); wrap.style.display='block'; }
        else wrap.style.display='none';
    });

    /* ── sections builder ── */
    function renderSections() {
        const container = F('sectionsContainer');
        const noMsg = F('noSectionsMsg');
        F('sectionCount').textContent = sections.length || '';
        F('sectionCount').style.display = sections.length ? 'inline' : 'none';
        noMsg.style.display = sections.length ? 'none' : 'block';
        container.innerHTML = '';
        sections.forEach((s, i) => {
            const card = document.createElement('div');
            card.className = 'card border-0 bg-light rounded-3 p-0';
            card.innerHTML = `
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="badge bg-secondary-subtle text-secondary">Section ${i + 1}</span>
                    <div class="d-flex gap-1">
                        ${i > 0 ? `<button type="button" class="btn btn-sm btn-ghost-secondary btn-move-up" data-idx="${i}" title="Move up"><i class="ti ti-arrow-up"></i></button>` : ''}
                        ${i < sections.length - 1 ? `<button type="button" class="btn btn-sm btn-ghost-secondary btn-move-down" data-idx="${i}" title="Move down"><i class="ti ti-arrow-down"></i></button>` : ''}
                        <button type="button" class="btn btn-sm btn-soft-danger btn-remove-section" data-idx="${i}"><i class="ti ti-trash"></i></button>
                    </div>
                </div>
                <div class="row g-2">
                    <div class="col-12"><input class="form-control form-control-sm sec-title" placeholder="Section heading" value="${escAttr(s.title||'')}" data-idx="${i}"></div>
                    <div class="col-12"><textarea class="form-control form-control-sm sec-body" rows="4" placeholder="Section body text…" data-idx="${i}">${escText(s.body||'')}</textarea></div>
                    <div class="col-md-8"><input class="form-control form-control-sm sec-image" placeholder="Image URL (optional)" value="${escAttr(s.image||'')}" data-idx="${i}"></div>
                    <div class="col-md-4"><input class="form-control form-control-sm sec-caption" placeholder="Caption" value="${escAttr(s.caption||'')}" data-idx="${i}"></div>
                </div>
            </div>`;
            container.appendChild(card);
        });
        /* live sync */
        container.querySelectorAll('.sec-title').forEach(el => el.addEventListener('input', e => { sections[+e.target.dataset.idx].title = e.target.value; F('sectionCount').textContent = sections.length; }));
        container.querySelectorAll('.sec-body').forEach(el => el.addEventListener('input', e => { sections[+e.target.dataset.idx].body = e.target.value; }));
        container.querySelectorAll('.sec-image').forEach(el => el.addEventListener('input', e => { sections[+e.target.dataset.idx].image = e.target.value; }));
        container.querySelectorAll('.sec-caption').forEach(el => el.addEventListener('input', e => { sections[+e.target.dataset.idx].caption = e.target.value; }));
        container.querySelectorAll('.btn-remove-section').forEach(el => el.addEventListener('click', e => { sections.splice(+e.currentTarget.dataset.idx, 1); renderSections(); }));
        container.querySelectorAll('.btn-move-up').forEach(el => el.addEventListener('click', e => { const i=+e.currentTarget.dataset.idx; [sections[i-1],sections[i]]=[sections[i],sections[i-1]]; renderSections(); }));
        container.querySelectorAll('.btn-move-down').forEach(el => el.addEventListener('click', e => { const i=+e.currentTarget.dataset.idx; [sections[i],sections[i+1]]=[sections[i+1],sections[i]]; renderSections(); }));
    }
    F('btnAddSection').addEventListener('click', () => { sections.push({title:'',body:'',image:'',caption:''}); renderSections(); /* switch to tab */ bootstrap.Tab.getOrCreateInstance(document.querySelector('[data-bs-target="#tab-sections"]')).show(); });

    function escAttr(s){ return String(s).replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
    function escText(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    /* ── open modal ── */
    function open(d) {
        F('f_id').value = d.id || '';
        F('mTitle').textContent = d.id ? 'Edit Post' : 'New Post';
        F('f_title').value = d.title || '';
        F('f_author').value = d.author || 'Grey InfoTech';
        F('f_author_role').value = d.authorRole || d['author-role'] || '';
        F('f_author_avatar').value = d.authorAvatar || d['author-avatar'] || '';
        if (F('f_author_avatar').value) { F('avatarPreview').src = F('f_author_avatar').value; F('avatarPreviewWrap').style.display='block'; }
        else F('avatarPreviewWrap').style.display='none';
        F('f_status').value = d.status || 'draft';
        F('f_published').value = d.published || '';
        F('f_cover').value = d.cover || '';
        F('f_hero_image').value = d.heroImage || d['hero-image'] || '';
        F('f_read_time').value = d.readTime || d['read-time'] || '';
        F('f_tags').value = d.tags || '';
        F('f_excerpt').value = d.excerpt || '';
        F('f_body').value = d.body || '';
        try { sections = JSON.parse(d.sections || '[]'); } catch(e) { sections = []; }
        renderSections();
        /* reset to first tab */
        bootstrap.Tab.getOrCreateInstance(document.querySelector('[data-bs-target="#tab-basic"]')).show();
        modal.show();
    }

    F('btnNew').addEventListener('click', () => open({}));
    document.querySelectorAll('.btn-edit').forEach(b => b.addEventListener('click', () => open(b.dataset)));

    /* ── save ── */
    F('btnSave').addEventListener('click', async () => {
        const id = F('f_id').value;
        /* sync any active section fields (already live-synced above) */
        const payload = {
            title: F('f_title').value.trim(),
            author: F('f_author').value.trim(),
            author_role: F('f_author_role').value.trim(),
            author_avatar: F('f_author_avatar').value.trim(),
            status: F('f_status').value,
            published_at: F('f_published').value || '',
            cover: F('f_cover').value.trim(),
            hero_image: F('f_hero_image').value.trim(),
            read_time: F('f_read_time').value.trim(),
            tags: F('f_tags').value,
            excerpt: F('f_excerpt').value.trim(),
            body: F('f_body').value.trim(),
            sections: JSON.stringify(sections),
        };
        if (!payload.title) return AdminAPI.toast('Title is required', true);
        const r = id ? await AdminAPI.patch('/blog/' + id, payload) : await AdminAPI.post('/blog', payload);
        if (r.ok) { AdminAPI.toast(r.message); location.reload(); } else AdminAPI.toast(r.message, true);
    });

    /* ── delete ── */
    document.querySelectorAll('.btn-del').forEach(b => b.addEventListener('click', async () => {
        if (!confirm('Delete this post? This cannot be undone.')) return;
        const r = await AdminAPI.del('/blog/' + b.dataset.id);
        if (r.ok) { AdminAPI.toast('Post deleted'); b.closest('tr').remove(); } else AdminAPI.toast(r.message, true);
    }));
})();
</script>
