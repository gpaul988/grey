<%- contentFor('html_attribute') %>
<%- contentFor('extra_css') %>
<%- contentFor('content') %>

<% const p = profile || (typeof user !== 'undefined' ? user : null); %>

<%- include('./partials/page-title', { title: title, subtitle: 'Account' }) %>

<% if (!p) { %>
<div class="alert alert-warning">Profile not available.</div>
<% } else { %>
<div class="row">
    <div class="col-xl-4">
        <div class="card">
            <div class="card-body text-center">
                <% if (typeof flash !== 'undefined' && flash) { %><div class="alert alert-success py-2"><%= flash %></div><% } %>
                <% if (typeof flashError !== 'undefined' && flashError) { %><div class="alert alert-danger py-2"><%= flashError %></div><% } %>
                <img src="<%= p.avatar || '/images/users/avatar-1.jpg' %>" class="rounded-circle mb-3" width="96" height="96" alt="avatar" style="object-fit:cover;">
                <form action="<%= adminBasePath %>/profile/avatar" method="post" enctype="multipart/form-data" class="mb-3">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="file" name="avatar" accept="image/*" class="form-control form-control-sm mb-2" required>
                    <button type="submit" class="btn btn-sm btn-outline-primary w-100"><i class="ti ti-upload me-1"></i>Update photo</button>
                    <p class="text-muted fs-12 mt-1 mb-0">JPEG, PNG, WebP or GIF · max 2&nbsp;MB</p>
                </form>
                <h4 class="mb-1"><%= p.name %></h4>
                <p class="text-muted mb-2 text-capitalize"><%= p.role %></p>
                <span class="badge bg-<%= p.status==='active'?'success':'secondary' %>-subtle text-<%= p.status==='active'?'success':'secondary' %> text-capitalize"><%= p.status %></span>
                <hr>
                <div class="text-start">
                    <p class="mb-2"><i class="ti ti-mail me-2 text-muted"></i><%= p.email %></p>
                    <p class="mb-2"><i class="ti ti-phone me-2 text-muted"></i><%= p.phone || 'Not set' %></p>
                    <p class="mb-0"><i class="ti ti-calendar me-2 text-muted"></i>Joined <%= timeAgo(p.created_at) %></p>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card">
            <div class="card-header"><h4 class="card-title mb-0">Edit Profile</h4></div>
            <div class="card-body">
                <input type="hidden" id="f_id" value="<%= p.id %>">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">Name</label><input id="f_name" class="form-control" value="<%= p.name %>"></div>
                    <div class="col-md-6"><label class="form-label">Email</label><input id="f_email" type="email" class="form-control" value="<%= p.email %>"></div>
                    <div class="col-md-6"><label class="form-label">Phone</label><input id="f_phone" class="form-control" value="<%= p.phone || '' %>"></div>
                    <div class="col-md-6"><label class="form-label">New password</label><input id="f_password" type="password" class="form-control" placeholder="Leave blank to keep current"></div>
                </div>
                <div class="mt-3">
                    <button class="btn btn-primary" id="btnSave">Save changes</button>
                </div>
                <p class="text-muted fs-13 mt-2 mb-0">Role and status can only be changed by an administrator from the Team page.</p>
            </div>
        </div>
    </div>
</div>

<%- contentFor('extra_javascript') %>
<%- include('./partials/admin-api-helper') %>
<script>
(function () {
    const F = (id) => document.getElementById(id);
    F('btnSave').addEventListener('click', async () => {
        const id = F('f_id').value;
        const payload = { name: F('f_name').value.trim(), email: F('f_email').value.trim(), phone: F('f_phone').value.trim() };
        const pw = F('f_password').value;
        if (pw) payload.password = pw;
        const r = await AdminAPI.patch('/me', payload);
        if (r.ok) { AdminAPI.toast('Profile updated'); setTimeout(() => location.reload(), 600); } else AdminAPI.toast(r.message, true);
    });
})();
</script>
<% } %>
