<%- contentFor('html_attribute') %>

<%- contentFor('extra_css') %>
<style>
    body {
        background:
            radial-gradient(circle at top right, rgba(29, 111, 215, 0.14), transparent 26%),
            radial-gradient(circle at bottom left, rgba(88, 80, 236, 0.12), transparent 24%),
            #f4f7fb;
    }

    .auth-shell {
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .auth-card {
        border: 0;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 24px 80px rgba(15, 23, 42, 0.14);
    }

    .auth-hero {
        background: linear-gradient(160deg, #1d6fd7 0%, #0f4c81 50%, #16213e 100%);
        color: #fff;
        padding: 3rem;
        position: relative;
    }

    .auth-hero::after {
        content: '';
        position: absolute;
        inset: auto auto -30% -18%;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.08);
    }

    .auth-badge {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .45rem .8rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        font-weight: 600;
        font-size: .85rem;
        letter-spacing: .03em;
    }

    .auth-form-panel {
        padding: 2rem;
        background: #fff;
    }

    .auth-footer {
        background: #f8fafc;
        border-top: 1px solid #e7edf5;
    }

    .auth-mini-logo {
        height: 30px;
    }

    .auth-copy {
        color: rgba(255, 255, 255, 0.82);
    }

    @media (max-width: 991.98px) {
        .auth-hero,
        .auth-form-panel {
            padding: 1.5rem;
        }
    }
</style>

<%- contentFor('body_attribute') %>
class="auth-shell"

<%- contentFor('content') %>
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="card auth-card">
                <div class="row g-0">
                    <div class="col-lg-5 auth-hero d-flex flex-column justify-content-between">
                        <div>
                            <a href="<%= adminBasePath %>/dashboard" class="d-inline-flex align-items-center mb-4 text-white text-decoration-none">
                                <img src="/logon.png" alt="Grey InfoTech logo" class="auth-mini-logo me-2">
                                <span class="fw-semibold fs-5">Grey InfoTech</span>
                            </a>

                            <span class="auth-badge mb-3">
                                <i class="ri-user-add-line"></i>
                                Join the platform
                            </span>

                            <h2 class="fw-bold mb-3">Create your account</h2>
                            <p class="auth-copy mb-4">Register now to get access to the project backend, dashboard pages, and future admin features.</p>

                            <div class="d-grid gap-3">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="ri-checkbox-circle-line fs-5"></i>
                                    <span>Simple onboarding</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <i class="ri-checkbox-circle-line fs-5"></i>
                                    <span>Consistent authentication flow</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <i class="ri-checkbox-circle-line fs-5"></i>
                                    <span>Matches the login experience</span>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 pt-2 auth-copy small">
                            &copy; <script>document.write(new Date().getFullYear())</script> Grey InfoTech
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <div class="auth-form-panel h-100 d-flex flex-column">
                            <div class="mb-4">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <img src="/logon.png" alt="Grey InfoTech logo" class="auth-mini-logo">
                                    <span class="text-uppercase fw-semibold text-primary small">Get started</span>
                                </div>
                                <h3 class="fw-bold mb-2">Create a new account</h3>
                                <p class="text-muted mb-0">Fill in your details to set up access to the dashboard.</p>
                            </div>

                            <% if (typeof formInfo !== 'undefined' && formInfo) { %>
                                <div class="alert alert-success border-0 rounded-3 mb-4"><%= formInfo %></div>
                            <% } %>
                            <% if (typeof formError !== 'undefined' && formError) { %>
                                <div class="alert alert-danger border-0 rounded-3 mb-4"><%= formError %></div>
                            <% } %>

                            <% if (typeof resendEmail !== 'undefined' && resendEmail) { %>
                                <form action="/resend-verification" method="post" class="mb-4">
                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                    <input type="hidden" name="email" value="<%= resendEmail %>">
                                    <button type="submit" class="btn btn-outline-primary w-100">
                                        <i class="ri-mail-send-line me-1"></i> Resend verification link
                                    </button>
                                </form>
                            <% } %>
                            <% if (typeof showLoginLink !== 'undefined' && showLoginLink) { %>
                                <a href="<%= loginPath %>" class="btn btn-primary w-100 mb-4">Go to login</a>
                            <% } %>

                            <form id="register-form" action="<%= registerPath %>" method="post" class="row g-3">
                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                <div class="col-12">
                                    <label for="name" class="form-label">Full name</label>
                                    <input
                                        type="text"
                                        class="form-control form-control-lg"
                                        id="name"
                                        name="name"
                                        placeholder="Your name"
                                        value="<%= formValues.name || '' %>"
                                        required>
                                </div>

                                <div class="col-12">
                                    <label for="email" class="form-label">Email address</label>
                                    <input
                                        type="email"
                                        class="form-control form-control-lg"
                                        id="email"
                                        name="email"
                                        placeholder="name@example.com"
                                        value="<%= formValues.email || '' %>"
                                        required>
                                </div>

                                <div class="col-md-6">
                                    <label for="password" class="form-label">Password</label>
                                    <div class="input-group input-group-lg">
                                        <input type="password" class="form-control" id="password" name="password" placeholder="Create password" required>
                                        <button type="button" class="btn btn-outline-secondary toggle-password" data-target="password" aria-label="Show password">
                                            <i class="ri-eye-line"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <label for="confirmPassword" class="form-label">Confirm password</label>
                                    <div class="input-group input-group-lg">
                                        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Repeat password" required>
                                        <button type="button" class="btn btn-outline-secondary toggle-password" data-target="confirmPassword" aria-label="Show password">
                                            <i class="ri-eye-line"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="terms" required>
                                        <label class="form-check-label" for="terms">I agree to the terms and conditions</label>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary btn-lg w-100">Create account</button>
                                </div>

                                <div class="col-12 text-center">
                                    <span class="text-muted small">Already have an account?</span>
                                    <a href="<%= loginPath %>" class="text-decoration-none fw-semibold ms-1">Back to login</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- contentFor('extra_javascript') %>
<script>
    document.querySelectorAll('.toggle-password').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var input = document.getElementById(btn.getAttribute('data-target'));
            if (!input) return;
            var icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                if (icon) icon.className = 'ri-eye-off-line';
                btn.setAttribute('aria-label', 'Hide password');
            } else {
                input.type = 'password';
                if (icon) icon.className = 'ri-eye-line';
                btn.setAttribute('aria-label', 'Show password');
            }
        });
    });
</script>