<%- contentFor('html_attribute') %>

<%- contentFor('extra_css') %>

<%- contentFor('body_attribute') %>
class="h-100"

<%- contentFor('content') %>

<div class="auth-bg d-flex min-vh-100">
    <div class="row g-0 justify-content-center w-100 m-xxl-5 px-xxl-4 m-3">
        <div class="col-xxl-3 col-lg-5 col-md-6">
            <a href="/" class="auth-brand d-flex justify-content-center mb-2">
                <img src="/images/logo-dark.png" alt="dark logo" height="26" class="logo-dark">
                <img src="/images/logo.png" alt="logo light" height="26" class="logo-light">
            </a>

            <p class="fw-semibold mb-4 text-center text-muted fs-15">Grey InfoTech Admin</p>

            <div class="card overflow-hidden text-center p-xxl-4 p-3 mb-0">

                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="mb-3"><i class="ti ti-circle-check-filled text-success" style="font-size:56px;"></i></div>
                    <h4 class="fw-semibold mb-2 fs-20 text-success"><%= heading || 'Success' %></h4>
                <% } else { %>
                    <div class="mb-3"><i class="ti ti-alert-circle-filled text-danger" style="font-size:56px;"></i></div>
                    <h4 class="fw-semibold mb-2 fs-20 text-danger"><%= heading || 'Something went wrong' %></h4>
                <% } %>

                <p class="text-muted fs-14 mt-2"><%= message %></p>

                <a href="<%= typeof loginPath !== 'undefined' ? loginPath : '/login' %>" class="btn d-block btn-primary mt-3">
                    Continue to Login
                </a>
            </div>

            <p class="mt-3 text-center mb-0">
                <%= new Date().getFullYear() %> © Grey InfoTech
            </p>
        </div>
    </div>
</div>
