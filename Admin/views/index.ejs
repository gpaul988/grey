<%- contentFor('html_attribute') %>
<%- contentFor('extra_css') %>
<%- contentFor('content') %>

<%- include('./partials/page-title', { title: title, subtitle: 'Overview' }) %>

<!-- Stat cards -->
<div class="row row-cols-xxl-4 row-cols-md-2 row-cols-1">
    <div class="col">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="avatar-md flex-shrink-0">
                        <span class="avatar-title bg-primary-subtle text-primary rounded fs-22">
                            <i class="ti ti-mail-opened"></i>
                        </span>
                    </div>
                    <h5 class="text-muted fs-13 fw-bold text-uppercase mb-0">New Submissions</h5>
                </div>
                <h3 class="mb-0 fw-bold"><%= stats.newSubmissions %></h3>
                <a href="/admin/submissions" class="text-decoration-underline fs-13 text-muted">View all submissions</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="avatar-md flex-shrink-0">
                        <span class="avatar-title bg-warning-subtle text-warning rounded fs-22">
                            <i class="ti ti-target-arrow"></i>
                        </span>
                    </div>
                    <h5 class="text-muted fs-13 fw-bold text-uppercase mb-0">Open Leads</h5>
                </div>
                <h3 class="mb-0 fw-bold"><%= stats.openLeads %> <small class="text-muted fs-13 fw-normal">/ <%= stats.totalLeads %> total</small></h3>
                <a href="/admin/leads" class="text-decoration-underline fs-13 text-muted">Manage pipeline</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="avatar-md flex-shrink-0">
                        <span class="avatar-title bg-success-subtle text-success rounded fs-22">
                            <i class="ti ti-cash"></i>
                        </span>
                    </div>
                    <h5 class="text-muted fs-13 fw-bold text-uppercase mb-0">Revenue (Paid)</h5>
                </div>
                <h3 class="mb-0 fw-bold"><%= fmtMoney(stats.paidRevenue) %></h3>
                <span class="fs-13 text-muted">Outstanding: <%= fmtMoney(stats.outstanding) %></span>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="avatar-md flex-shrink-0">
                        <span class="avatar-title bg-info-subtle text-info rounded fs-22">
                            <i class="ti ti-briefcase"></i>
                        </span>
                    </div>
                    <h5 class="text-muted fs-13 fw-bold text-uppercase mb-0">Active Projects</h5>
                </div>
                <h3 class="mb-0 fw-bold"><%= stats.activeProjects %> <small class="text-muted fs-13 fw-normal">/ <%= stats.totalProjects %> total</small></h3>
                <a href="/admin/projects" class="text-decoration-underline fs-13 text-muted">View projects</a>
            </div>
        </div>
    </div>
</div>

<!-- Secondary stats -->
<div class="row row-cols-xxl-4 row-cols-md-2 row-cols-1">
    <div class="col">
        <div class="card">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="text-muted fs-13 mb-1">Open Tickets</h5>
                    <h4 class="mb-0 fw-bold"><%= stats.openTickets %></h4>
                </div>
                <span class="avatar-title bg-danger-subtle text-danger rounded fs-22"><i class="ti ti-ticket"></i></span>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="text-muted fs-13 mb-1">Clients</h5>
                    <h4 class="mb-0 fw-bold"><%= stats.totalClients %></h4>
                </div>
                <span class="avatar-title bg-primary-subtle text-primary rounded fs-22"><i class="ti ti-users"></i></span>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="text-muted fs-13 mb-1">Published Posts</h5>
                    <h4 class="mb-0 fw-bold"><%= stats.publishedPosts %></h4>
                </div>
                <span class="avatar-title bg-success-subtle text-success rounded fs-22"><i class="ti ti-article"></i></span>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="text-muted fs-13 mb-1">Won Lead Value</h5>
                    <h4 class="mb-0 fw-bold"><%= fmtMoney(stats.wonValue) %></h4>
                </div>
                <span class="avatar-title bg-warning-subtle text-warning rounded fs-22"><i class="ti ti-trophy"></i></span>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Recent submissions -->
    <div class="col-xl-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Recent Form Submissions</h4>
                <a href="/admin/submissions" class="btn btn-sm btn-soft-primary">View all</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-centered mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr>
                            <th>Name</th><th>Subject</th><th>Status</th><th>When</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!recentSubmissions.length) { %>
                        <tr><td colspan="4" class="text-center text-muted py-4">No submissions yet</td></tr>
                        <% } %>
                        <% recentSubmissions.forEach((s) => { %>
                        <tr>
                            <td>
                                <div class="fw-medium"><%= s.name %></div>
                                <small class="text-muted"><%= s.email %></small>
                            </td>
                            <td><%= s.subject || s.project_type || '—' %></td>
                            <td><span class="badge bg-<%= s.status === 'new' ? 'danger' : (s.status === 'replied' ? 'success' : 'secondary') %>-subtle text-<%= s.status === 'new' ? 'danger' : (s.status === 'replied' ? 'success' : 'secondary') %> text-capitalize"><%= s.status %></span></td>
                            <td class="text-muted fs-13"><%= timeAgo(s.created_at) %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Active projects -->
    <div class="col-xl-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Active Projects</h4>
                <a href="/admin/projects" class="btn btn-sm btn-soft-primary">View all</a>
            </div>
            <div class="card-body">
                <% if (!activeProjects.length) { %>
                <p class="text-center text-muted py-4 mb-0">No active projects</p>
                <% } %>
                <% activeProjects.forEach((p) => { %>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <a href="/admin/projects" class="fw-medium text-reset"><%= p.name %></a>
                        <span class="text-muted fs-13"><%= p.progress %>%</span>
                    </div>
                    <div class="progress" style="height:6px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: <%= p.progress %>%"></div>
                    </div>
                    <small class="text-muted"><%= p.client_name || 'No client' %> · <%= fmtMoney(p.budget) %></small>
                </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Recent leads -->
    <div class="col-xl-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Recent Leads</h4>
                <a href="/admin/leads" class="btn btn-sm btn-soft-primary">Pipeline</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-centered mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr><th>Name</th><th>Company</th><th>Stage</th><th>Value</th></tr>
                    </thead>
                    <tbody>
                        <% if (!recentLeads.length) { %>
                        <tr><td colspan="4" class="text-center text-muted py-4">No leads yet</td></tr>
                        <% } %>
                        <% recentLeads.forEach((l) => { %>
                        <tr>
                            <td><div class="fw-medium"><%= l.name %></div><small class="text-muted"><%= l.email %></small></td>
                            <td><%= l.company || '—' %></td>
                            <td><span class="badge bg-info-subtle text-info text-capitalize"><%= l.stage %></span></td>
                            <td class="fw-medium"><%= fmtMoney(l.value) %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Activity feed -->
    <div class="col-xl-5">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Activity</h4>
                <a href="/admin/activity" class="btn btn-sm btn-soft-primary">Full log</a>
            </div>
            <div class="card-body">
                <% if (!recentActivity.length) { %>
                <p class="text-center text-muted py-4 mb-0">No activity recorded</p>
                <% } %>
                <div class="timeline-alt pb-0">
                    <% recentActivity.forEach((a) => { %>
                    <div class="d-flex align-items-start mb-3">
                        <span class="avatar-sm flex-shrink-0 me-2">
                            <span class="avatar-title bg-light text-primary rounded-circle"><i class="ti ti-point"></i></span>
                        </span>
                        <div>
                            <p class="mb-0 fs-14"><strong><%= a.user_name || 'System' %></strong> <%= a.action %> <%= a.entity || '' %></p>
                            <% if (a.detail) { %><small class="text-muted"><%= a.detail %></small><br><% } %>
                            <small class="text-muted"><%= timeAgo(a.created_at) %></small>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>
