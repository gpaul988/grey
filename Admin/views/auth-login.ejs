<%- contentFor('html_attribute') %>

<%- contentFor('extra_css') %>
<style>
    body {
        background:
            radial-gradient(circle at top left, rgba(13, 110, 253, 0.12), transparent 28%),
            radial-gradient(circle at bottom right, rgba(88, 80, 236, 0.14), transparent 24%),
            #f4f7fb;
    }

    .auth-shell {
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .auth-card {
        border: 0;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 24px 80px rgba(15, 23, 42, 0.14);
    }

    .auth-hero {
        background: linear-gradient(160deg, #16213e 0%, #0f4c81 55%, #1d6fd7 100%);
        color: #fff;
        padding: 3rem;
        position: relative;
    }

    .auth-hero::after {
        content: '';
        position: absolute;
        inset: auto -20% -35% auto;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.08);
        filter: blur(2px);
    }

    .auth-badge {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .45rem .8rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        font-weight: 600;
        font-size: .85rem;
        letter-spacing: .03em;
    }

    .auth-form-panel {
        padding: 2rem;
        background: #fff;
    }

    .auth-footer {
        background: #f8fafc;
        border-top: 1px solid #e7edf5;
    }

    .auth-mini-logo {
        height: 30px;
    }

    .auth-copy {
        color: rgba(255, 255, 255, 0.82);
    }

    .auth-feature-list li + li {
        margin-top: .8rem;
    }

    @media (max-width: 991.98px) {
        .auth-hero,
        .auth-form-panel {
            padding: 1.5rem;
        }
    }
</style>

<%- contentFor('body_attribute') %>
class="auth-shell"

<%- contentFor('content') %>
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="card auth-card">
                <div class="row g-0">
                    <div class="col-lg-5 auth-hero d-flex flex-column justify-content-between">
                        <div>
                            <a href="<%= adminBasePath %>/dashboard" class="d-inline-flex align-items-center mb-4 text-white text-decoration-none">
                                <img src="/logon.png" alt="Grey InfoTech logo" class="auth-mini-logo me-2">
                                <span class="fw-semibold fs-5">Grey InfoTech</span>
                            </a>

                            <span class="auth-badge mb-3">
                                <i class="ri-shield-check-line"></i>
                                Secure access
                            </span>

                            <h2 class="fw-bold mb-3">Sign in to your workspace</h2>
                            <p class="auth-copy mb-4">A clean Porto-inspired sign-in experience with a streamlined footer action and a clear path to registration.</p>

                            <ul class="list-unstyled auth-feature-list mb-0">
                                <li class="d-flex align-items-center gap-2">
                                    <i class="ri-checkbox-circle-line fs-5"></i>
                                    <span>Fast login flow</span>
                                </li>
                                <li class="d-flex align-items-center gap-2">
                                    <i class="ri-checkbox-circle-line fs-5"></i>
                                    <span>Register button available instantly</span>
                                </li>
                                <li class="d-flex align-items-center gap-2">
                                    <i class="ri-checkbox-circle-line fs-5"></i>
                                    <span>Responsive layout for mobile and desktop</span>
                                </li>
                            </ul>
                        </div>

                        <div class="mt-4 pt-2 auth-copy small">
                            &copy; <script>document.write(new Date().getFullYear())</script> Grey InfoTech
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <div class="auth-form-panel h-100 d-flex flex-column">
                            <div class="mb-4">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <img src="/logon.png" alt="Grey InfoTech logo" class="auth-mini-logo">
                                    <span class="text-uppercase fw-semibold text-primary small">Welcome back</span>
                                </div>
                                <h3 class="fw-bold mb-2">Log in to continue</h3>
                                <p class="text-muted mb-0">Use your account credentials to access the admin dashboard.</p>
                            </div>

                            <% if (typeof formInfo !== 'undefined' && formInfo) { %>
                                <div class="alert alert-success border-0 rounded-3 mb-4"><%= formInfo %></div>
                            <% } %>
                            <% if (typeof formError !== 'undefined' && formError) { %>
                                <div class="alert alert-danger border-0 rounded-3 mb-4"><%= formError %></div>
                            <% } %>

                            <form id="login-form" action="<%= loginPath %>" method="post" class="row g-3">
                                <div class="col-12">
                                    <label for="email" class="form-label">Email address</label>
                                    <input
                                        type="email"
                                        class="form-control form-control-lg"
                                        id="email"
                                        name="email"
                                        placeholder="name@example.com"
                                        value="<%= formValues.email || '' %>"
                                        autocomplete="username"
                                        required>
                                </div>

                                <div class="col-12">
                                    <label for="password" class="form-label">Password</label>
                                    <input
                                        type="password"
                                        class="form-control form-control-lg"
                                        id="password"
                                        name="password"
                                        placeholder="Enter your password"
                                        autocomplete="current-password"
                                        required>
                                </div>

                                <div class="col-12 d-flex flex-wrap justify-content-between align-items-center gap-2">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="remember-me" name="remember">
                                        <label class="form-check-label" for="remember-me">Remember me</label>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary btn-lg w-100">Log in</button>
                                </div>

                                <div class="col-12 text-center">
                                    <span class="text-muted small">Don't have an account?</span>
                                    <a href="<%= registerPath %>" class="text-decoration-none fw-semibold ms-1">Create account</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- contentFor('extra_javascript') %>