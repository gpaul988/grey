<!doctype html>
<html lang="en"><head><%- include('_head') %></head>
<body>
  <%- include('_nav') %>
  <div class="container pb-5" style="max-width:820px;">

    <h4 class="mb-1"><i class="bi bi-people text-teal"></i> My Team</h4>
    <p class="text-muted">Invite up to <%= max %> team members to access your projects and join conversations.</p>

    <% if (info) { %><div class="alert alert-success py-2"><%= info %></div><% } %>
    <% if (error) { %><div class="alert alert-warning py-2"><%= error %></div><% } %>

    <% if (!paid) { %>
      <div class="card p-4 mb-4 locked">
        <div class="d-flex align-items-center gap-3">
          <i class="bi bi-lock-fill fs-3 text-muted"></i>
          <div>
            <strong>Team invites unlock after payment</strong>
            <div class="text-muted small">Once your first invoice is paid, you'll be able to add team members here.</div>
          </div>
        </div>
      </div>
    <% } %>

    <div class="card p-4 mb-4 <%= paid ? '' : 'locked' %>">
      <h6 class="mb-3">Invite a team member</h6>
      <form method="POST" action="/portal/staff" class="row g-3">
                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="col-md-5">
          <label class="form-label small">Full name</label>
          <input name="name" class="form-control" <%= paid ? '' : 'disabled' %> required>
        </div>
        <div class="col-md-4">
          <label class="form-label small">Email</label>
          <input type="email" name="email" class="form-control" <%= paid ? '' : 'disabled' %> required>
        </div>
        <div class="col-md-3">
          <label class="form-label small">Role</label>
          <input name="role_title" class="form-control" placeholder="e.g. Manager" <%= paid ? '' : 'disabled' %>>
        </div>
        <div class="col-12">
          <button class="btn btn-teal fw-semibold" <%= paid ? '' : 'disabled' %>>Send invite</button>
          <span class="text-muted small ms-2"><%= staff.length %>/<%= max %> used</span>
        </div>
      </form>
    </div>

    <div class="card p-4">
      <h6 class="mb-3">Team members</h6>
      <% if (!staff || staff.length === 0) { %>
        <p class="text-muted small mb-0">No team members yet.</p>
      <% } else { %>
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead><tr class="small text-muted"><th></th><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th></th></tr></thead>
            <tbody>
              <% staff.forEach(function(s){ %>
                <tr>
                  <td><% if (s.avatar) { %><img src="<%= s.avatar %>" class="avatar"><% } else { %><span class="avatar d-inline-flex align-items-center justify-content-center"><i class="bi bi-person"></i></span><% } %></td>
                  <td><%= s.name %></td>
                  <td class="small text-muted"><%= s.email %></td>
                  <td class="small"><%= s.role_title || '—' %></td>
                  <td><% if (s.email_verified) { %><span class="chip" style="background:#d1fae5;color:#047857;">Active</span><% } else { %><span class="chip bg-light text-muted">Invited</span><% } %></td>
                  <td class="text-end">
                    <form method="POST" action="/portal/staff/<%= s.id %>
                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">/delete" onsubmit="return confirm('Remove this team member?')">
                      <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </div>
</body></html>
