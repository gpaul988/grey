<!doctype html>
<html lang="en"><head><%- include('_head') %></head>
<body class="d-flex align-items-center min-vh-100">
  <div class="container" style="max-width:430px;">
    <div class="text-center mb-4"><span class="brand fs-2">Grey InfoTech</span><div class="text-muted">Client Portal</div></div>
    <div class="card p-4 shadow-sm">
      <h5 class="mb-1">Set your password</h5>
      <% if (name) { %><p class="text-muted small mb-3">Welcome, <strong><%= name %></strong>. Create a password to activate your account.</p><% } %>
      <% if (error) { %><div class="alert alert-warning py-2"><%= error %></div><% } %>
      <form method="POST" action="/portal/set-password/<%= token %>
                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">">
        <div class="mb-3">
          <label class="form-label small">New password <span class="text-muted">(min 8 chars)</span></label>
          <input type="password" name="password" class="form-control" required minlength="8">
        </div>
        <div class="mb-3">
          <label class="form-label small">Confirm password</label>
          <input type="password" name="confirmPassword" class="form-control" required minlength="8">
        </div>
        <button class="btn btn-teal w-100 fw-semibold">Set password &amp; verify</button>
      </form>
    </div>
    <p class="text-center text-muted small mt-3"><%= new Date().getFullYear() %> © Grey InfoTech</p>
  </div>
</body></html>
