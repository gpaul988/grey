<%- contentFor('html_attribute') %>

<%- contentFor('content') %>

    <%- include('./partials/page-title', {title: 'Coupons & Discounts', subtitle: 'Store'}) %>

    <div class="row g-3">
        <div class="col-xl-4">
            <div class="card">
                <div class="card-header"><h5 class="card-title mb-0">Create Coupon</h5></div>
                <div class="card-body">
                    <form method="POST" action="/admin/store/coupons">
                        <div class="mb-3">
                            <label class="form-label">Code <span class="text-danger">*</span></label>
                            <input type="text" name="code" class="form-control text-uppercase" required placeholder="e.g. WELCOME10">
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Type</label>
                                <select name="type" class="form-select" id="newType">
                                    <option value="percent">Percentage (%)</option>
                                    <option value="fixed">Fixed (₦)</option>
                                </select>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Value <span class="text-danger">*</span></label>
                                <input type="number" name="value" class="form-control" required min="0" step="0.01" placeholder="10">
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Min. Subtotal (₦)</label>
                                <input type="number" name="min_subtotal" class="form-control" min="0" step="0.01" placeholder="0">
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Max Discount (₦)</label>
                                <input type="number" name="max_discount" class="form-control" min="0" step="0.01" placeholder="Optional cap">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Usage Limit</label>
                            <input type="number" name="usage_limit" class="form-control" min="0" placeholder="Unlimited if blank">
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Starts</label>
                                <input type="date" name="starts_at" class="form-control">
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Expires</label>
                                <input type="date" name="expires_at" class="form-control">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select name="status" class="form-select">
                                <option value="active">Active</option>
                                <option value="disabled">Disabled</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100"><i class="ti ti-plus me-1"></i>Create Coupon</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="card">
                <div class="card-header"><h5 class="card-title mb-0">All Coupons (<%= coupons.length %>)</h5></div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr><th>Code</th><th>Discount</th><th>Min / Cap</th><th>Used</th><th>Validity</th><th>Status</th><th></th></tr>
                            </thead>
                            <tbody>
                                <% if(coupons.length === 0) { %>
                                <tr><td colspan="7" class="text-center text-muted py-4">No coupons yet. Create one to offer discounts.</td></tr>
                                <% } %>
                                <% coupons.forEach(c => { %>
                                <tr>
                                    <td><code class="fs-6"><%= c.code %></code></td>
                                    <td><%= c.type === 'percent' ? c.value + '%' : '₦' + Number(c.value).toLocaleString() %></td>
                                    <td class="small text-muted">
                                        Min ₦<%= Number(c.min_subtotal||0).toLocaleString() %><br>
                                        <%= c.max_discount ? 'Cap ₦' + Number(c.max_discount).toLocaleString() : 'No cap' %>
                                    </td>
                                    <td><%= c.used_count || 0 %><%= c.usage_limit ? ' / ' + c.usage_limit : '' %></td>
                                    <td class="small text-muted">
                                        <%= c.starts_at ? new Date(c.starts_at).toLocaleDateString() : 'Now' %> –
                                        <%= c.expires_at ? new Date(c.expires_at).toLocaleDateString() : '∞' %>
                                    </td>
                                    <td><span class="badge bg-<%= c.status === 'active' ? 'success' : 'secondary' %>-subtle text-<%= c.status === 'active' ? 'success' : 'secondary' %>"><%= c.status %></span></td>
                                    <td class="text-nowrap">
                                        <button class="btn btn-sm btn-soft-primary btn-edit"
                                            data-id="<%= c.id %>" data-code="<%= c.code %>" data-type="<%= c.type %>" data-value="<%= c.value %>"
                                            data-min="<%= c.min_subtotal || '' %>" data-max="<%= c.max_discount || '' %>" data-limit="<%= c.usage_limit || '' %>"
                                            data-starts="<%= c.starts_at ? c.starts_at.slice(0,10) : '' %>" data-expires="<%= c.expires_at ? c.expires_at.slice(0,10) : '' %>" data-status="<%= c.status %>">
                                            <i class="ti ti-edit"></i>
                                        </button>
                                        <form method="POST" action="/admin/store/coupons/<%= c.id %>/delete" class="d-inline frm-del">
                                            <button type="submit" class="btn btn-sm btn-soft-danger"><i class="ti ti-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Modal -->
    <div class="modal fade" id="editModal" tabindex="-1">
        <div class="modal-dialog">
            <form class="modal-content" method="POST" id="editForm">
                <div class="modal-header"><h5 class="modal-title">Edit Coupon</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label">Code</label><input name="code" id="e_code" class="form-control text-uppercase" required></div>
                    <div class="row">
                        <div class="col-6 mb-3"><label class="form-label">Type</label><select name="type" id="e_type" class="form-select"><option value="percent">Percentage (%)</option><option value="fixed">Fixed (₦)</option></select></div>
                        <div class="col-6 mb-3"><label class="form-label">Value</label><input type="number" name="value" id="e_value" class="form-control" step="0.01" required></div>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3"><label class="form-label">Min. Subtotal</label><input type="number" name="min_subtotal" id="e_min" class="form-control" step="0.01"></div>
                        <div class="col-6 mb-3"><label class="form-label">Max Discount</label><input type="number" name="max_discount" id="e_max" class="form-control" step="0.01"></div>
                    </div>
                    <div class="mb-3"><label class="form-label">Usage Limit</label><input type="number" name="usage_limit" id="e_limit" class="form-control"></div>
                    <div class="row">
                        <div class="col-6 mb-3"><label class="form-label">Starts</label><input type="date" name="starts_at" id="e_starts" class="form-control"></div>
                        <div class="col-6 mb-3"><label class="form-label">Expires</label><input type="date" name="expires_at" id="e_expires" class="form-control"></div>
                    </div>
                    <div class="mb-0"><label class="form-label">Status</label><select name="status" id="e_status" class="form-select"><option value="active">Active</option><option value="disabled">Disabled</option></select></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Save</button></div>
            </form>
        </div>
    </div>

<%- contentFor('extra_javascript') %>
<script>
document.querySelectorAll('.btn-edit').forEach(function(b){
  b.addEventListener('click', function(){
    var d = b.dataset;
    document.getElementById('editForm').action = '/admin/store/coupons/' + d.id + '/edit';
    document.getElementById('e_code').value = d.code;
    document.getElementById('e_type').value = d.type;
    document.getElementById('e_value').value = d.value;
    document.getElementById('e_min').value = d.min;
    document.getElementById('e_max').value = d.max;
    document.getElementById('e_limit').value = d.limit;
    document.getElementById('e_starts').value = d.starts;
    document.getElementById('e_expires').value = d.expires;
    document.getElementById('e_status').value = d.status;
    new bootstrap.Modal(document.getElementById('editModal')).show();
  });
});
</script>
