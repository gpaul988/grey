<%- contentFor('html_attribute') %>

<%- contentFor('extra_css') %>
<link href="/vendor/dropzone/min/dropzone.min.css" rel="stylesheet">

<%- contentFor('content') %>

    <%- include('./partials/page-title', {title: product ? 'Edit Product' : 'New Product', subtitle: 'Store'}) %>

    <form id="productForm" method="POST" action="<%= product ? '/admin/store/products/' + product.id + '/edit' : '/admin/store/products/new' %>" enctype="multipart/form-data">
        <div class="row g-3">
            <!-- LEFT COLUMN -->
            <div class="col-xl-8">
                <div class="card mb-3">
                    <div class="card-header"><h5 class="card-title mb-0">Basic Information</h5></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Product Name <span class="text-danger">*</span></label>
                            <input type="text" name="name" class="form-control" value="<%= product?.name || '' %>" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">SKU</label>
                                <input type="text" name="sku" class="form-control" value="<%= product?.sku || '' %>" placeholder="Auto-generated if blank">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Weight (kg)</label>
                                <input type="number" name="weight" class="form-control" value="<%= product?.weight || '' %>" step="0.01">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="description" id="descriptionEditor" class="form-control" rows="6"><%= product?.description || '' %></textarea>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header"><h5 class="card-title mb-0">Specifications</h5></div>
                    <div class="card-body">
                        <p class="text-muted small">Add technical specs as key-value pairs (e.g. RAM → 16GB, Processor → Intel i7)</p>
                        <div id="specsContainer">
                            <% const specs = JSON.parse(product?.specs || '{}'); %>
                            <% if(Object.keys(specs).length > 0) { %>
                                <% Object.entries(specs).forEach(([k,v]) => { %>
                                <div class="row g-2 mb-2 spec-row">
                                    <div class="col-5"><input type="text" name="spec_key[]" class="form-control" placeholder="Key" value="<%= k %>"></div>
                                    <div class="col-5"><input type="text" name="spec_val[]" class="form-control" placeholder="Value" value="<%= v %>"></div>
                                    <div class="col-2"><button type="button" class="btn btn-soft-danger w-100" onclick="this.closest('.spec-row').remove()"><i class="ti ti-x"></i></button></div>
                                </div>
                                <% }) %>
                            <% } else { %>
                            <div class="row g-2 mb-2 spec-row">
                                <div class="col-5"><input type="text" name="spec_key[]" class="form-control" placeholder="e.g. RAM"></div>
                                <div class="col-5"><input type="text" name="spec_val[]" class="form-control" placeholder="e.g. 16GB"></div>
                                <div class="col-2"><button type="button" class="btn btn-soft-danger w-100" onclick="this.closest('.spec-row').remove()"><i class="ti ti-x"></i></button></div>
                            </div>
                            <% } %>
                        </div>
                        <button type="button" class="btn btn-soft-primary btn-sm mt-2" onclick="addSpec()"><i class="ti ti-plus me-1"></i>Add Spec</button>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header"><h5 class="card-title mb-0">Images</h5></div>
                    <div class="card-body">
                        <% const imgs = JSON.parse(product?.images || '[]'); %>
                        <% if(imgs.length > 0) { %>
                        <div class="row g-2 mb-3" id="existingImages">
                            <% imgs.forEach((img, i) => { %>
                            <div class="col-auto" id="img-<%= i %>">
                                <div class="position-relative">
                                    <img src="<%= img %>" class="rounded border" style="width:90px;height:90px;object-fit:cover">
                                    <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0" style="width:20px;height:20px;line-height:1" onclick="removeExistingImage(<%= i %>, '<%= img %>')"><i class="ti ti-x" style="font-size:10px"></i></button>
                                    <input type="hidden" name="existing_images[]" value="<%= img %>" id="ei-<%= i %>">
                                </div>
                            </div>
                            <% }) %>
                        </div>
                        <% } %>
                        <label class="form-label">Upload New Images</label>
                        <input type="file" name="product_images" class="form-control" accept="image/*" multiple>
                        <small class="text-muted">Max 8 images. First image becomes thumbnail.</small>
                    </div>
                </div>
            </div>

            <!-- RIGHT COLUMN -->
            <div class="col-xl-4">
                <div class="card mb-3">
                    <div class="card-header"><h5 class="card-title mb-0">Pricing & Stock</h5></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Price (₦) <span class="text-danger">*</span></label>
                            <input type="number" name="price" class="form-control" value="<%= product?.price || '' %>" min="0" step="0.01" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Compare at Price (₦)</label>
                            <input type="number" name="compare_price" class="form-control" value="<%= product?.compare_price || '' %>" min="0" step="0.01" placeholder="Original price (crossed out)">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Price (USD) <span class="text-muted small">— optional override</span></label>
                            <input type="number" name="price_usd" class="form-control" value="<%= product?.price_usd || '' %>" min="0" step="0.01" placeholder="Leave blank to auto-convert from ₦ via USD rate">
                            <small class="text-muted">If blank, USD price is calculated from the Naira price using the store USD rate.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Stock Quantity <span class="text-danger">*</span></label>
                            <input type="number" name="stock" class="form-control" value="<%= product?.stock ?? 0 %>" min="0" required>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header"><h5 class="card-title mb-0">Organization</h5></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <select name="category_id" class="form-select">
                                <option value="">— Select Category —</option>
                                <% categories.forEach(c => { %>
                                <option value="<%= c.id %>" <%= product?.category_id == c.id ? 'selected' : '' %>><%= c.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Brand</label>
                            <select name="brand_id" class="form-select">
                                <option value="">— Select Brand —</option>
                                <% brands.forEach(b => { %>
                                <option value="<%= b.id %>" <%= product?.brand_id == b.id ? 'selected' : '' %>><%= b.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tags</label>
                            <input type="text" name="tags" class="form-control" value="<%= JSON.parse(product?.tags || '[]').join(', ') %>" placeholder="laptop, gaming, 2024">
                            <small class="text-muted">Comma-separated</small>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header"><h5 class="card-title mb-0">Status</h5></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select name="status" class="form-select">
                                <option value="draft" <%= (product?.status || 'draft') === 'draft' ? 'selected' : '' %>>Draft</option>
                                <option value="active" <%= product?.status === 'active' ? 'selected' : '' %>>Active (Visible in store)</option>
                                <option value="archived" <%= product?.status === 'archived' ? 'selected' : '' %>>Archived</option>
                            </select>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="featured" id="featuredToggle" value="1" <%= product?.featured ? 'checked' : '' %>>
                            <label class="form-check-label" for="featuredToggle">Featured Product</label>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary"><i class="ti ti-device-floppy me-1"></i> Save Product</button>
                    <a href="/admin/store/products" class="btn btn-light">Cancel</a>
                </div>
            </div>
        </div>
    </form>

<%- contentFor('extra_javascript') %>
<script>
function addSpec() {
    const container = document.getElementById('specsContainer');
    const row = document.createElement('div');
    row.className = 'row g-2 mb-2 spec-row';
    row.innerHTML = '<div class="col-5"><input type="text" name="spec_key[]" class="form-control" placeholder="Key"></div><div class="col-5"><input type="text" name="spec_val[]" class="form-control" placeholder="Value"></div><div class="col-2"><button type="button" class="btn btn-soft-danger w-100" onclick="this.closest(\'.spec-row\').remove()"><i class="ti ti-x"></i></button></div>';
    container.appendChild(row);
}
function removeExistingImage(i, url) {
    document.getElementById('img-'+i)?.remove();
    document.getElementById('ei-'+i)?.remove();
}
</script>
