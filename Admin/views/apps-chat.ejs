<%- contentFor('html_attribute') %>
<%- contentFor('extra_css') %>
<%- contentFor('content') %>

<%- include('./partials/page-title', { title: title, subtitle: 'Messaging' }) %>

<div class="row">
    <!-- Conversation list -->
    <div class="col-xl-4">
        <div class="card" style="height: calc(100vh - 220px);">
            <div class="card-header"><h5 class="card-title mb-0">Conversations</h5></div>
            <div class="card-body p-0" style="overflow-y:auto;">
                <% if (!conversations.length) { %>
                <p class="text-center text-muted py-4 mb-0">No conversations.</p>
                <% } %>
                <div class="list-group list-group-flush" id="convList">
                    <% conversations.forEach((c) => { %>
                    <a href="#" class="list-group-item list-group-item-action conv-item <%= (activeConversation && activeConversation.id===c.id)?'active':'' %>" data-id="<%= c.id %>">
                        <div class="d-flex justify-content-between">
                            <span class="fw-medium"><%= c.subject || ('Conversation #' + c.id) %></span>
                            <% if (c.unread) { %><span class="badge bg-danger rounded-pill"><%= c.unread %></span><% } %>
                        </div>
                        <small class="d-block text-truncate <%= (activeConversation && activeConversation.id===c.id)?'text-white-50':'text-muted' %>"><%= c.last_message || 'No messages yet' %></small>
                        <small class="<%= (activeConversation && activeConversation.id===c.id)?'text-white-50':'text-muted' %>"><%= timeAgo(c.updated_at) %></small>
                    </a>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>

    <!-- Message thread -->
    <div class="col-xl-8">
        <div class="card" style="height: calc(100vh - 220px); display:flex; flex-direction:column;">
            <div class="card-header">
                <h5 class="card-title mb-0" id="threadTitle"><%= activeConversation ? (activeConversation.subject || ('Conversation #' + activeConversation.id)) : 'Select a conversation' %></h5>
            </div>
            <div class="card-body flex-grow-1" style="overflow-y:auto;" id="msgBox">
                <% if (!activeConversation) { %>
                <p class="text-center text-muted py-5">Choose a conversation from the left to view messages.</p>
                <% } else if (!messages.length) { %>
                <p class="text-center text-muted py-5" id="noMsg">No messages yet. Start the conversation below.</p>
                <% } %>
                <% (messages||[]).forEach((m) => { %>
                <div class="d-flex mb-3 <%= m.sender==='staff' ? 'flex-row-reverse text-end' : '' %>">
                    <div class="<%= m.sender==='staff' ? 'ms-2' : 'me-2' %>">
                        <span class="avatar-sm"><span class="avatar-title bg-<%= m.sender==='staff'?'primary':'secondary' %>-subtle text-<%= m.sender==='staff'?'primary':'secondary' %> rounded-circle"><%= (m.sender_name||'?').charAt(0) %></span></span>
                    </div>
                    <div>
                        <div class="p-2 px-3 rounded bg-<%= m.sender==='staff'?'primary-subtle':'light' %> d-inline-block"><%= m.body %></div>
                        <div><small class="text-muted"><%= m.sender_name || (m.sender==='staff'?'Staff':'Client') %> · <%= timeAgo(m.created_at) %></small></div>
                    </div>
                </div>
                <% }) %>
            </div>
            <% if (activeConversation) { %>
            <div class="card-footer">
                <div class="input-group">
                    <input id="msgInput" class="form-control" placeholder="Type a message..." data-conv="<%= activeConversation.id %>">
                    <button class="btn btn-primary" id="btnSend"><i class="ti ti-send"></i></button>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</div>

<%- contentFor('extra_javascript') %>
<%- include('./partials/admin-api-helper') %>
<script>
(function () {
    const F = (id) => document.getElementById(id);
    // Navigate to a conversation (server re-renders with it active and marks read)
    document.querySelectorAll('.conv-item').forEach(a => a.addEventListener('click', (e) => {
        e.preventDefault();
        location.href = '/admin/chat?c=' + a.dataset.id;
    }));
    const sendBtn = F('btnSend');
    if (sendBtn) {
        const send = async () => {
            const input = F('msgInput');
            const body = input.value.trim();
            if (!body) return;
            const r = await AdminAPI.post('/conversations/' + input.dataset.conv + '/messages', { body });
            if (r.ok) { location.reload(); } else AdminAPI.toast(r.message, true);
        };
        sendBtn.addEventListener('click', send);
        F('msgInput').addEventListener('keydown', (e) => { if (e.key === 'Enter') send(); });
    }
    const box = F('msgBox'); if (box) box.scrollTop = box.scrollHeight;
})();
</script>
