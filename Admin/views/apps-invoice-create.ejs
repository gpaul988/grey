<%- contentFor('html_attribute') %>
<%- contentFor('extra_css') %>
<%- contentFor('content') %>

<%- include('./partials/page-title', { title: title, subtitle: 'Billing' }) %>

<div class="row justify-content-center">
    <div class="col-xl-9">
        <div class="card">
            <div class="card-header"><h4 class="card-title mb-0">Create Invoice</h4></div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Client</label>
                        <select id="f_client" class="form-select">
                            <option value="">— Manual entry —</option>
                            <% clients.forEach(c=>{ %><option value="<%= c.id %>" data-name="<%= c.name %>" data-email="<%= c.email %>"><%= c.name %><%= c.company?(' ('+c.company+')'):'' %></option><% }) %>
                        </select>
                    </div>
                    <div class="col-md-3"><label class="form-label">Currency</label><select id="f_currency" class="form-select"><option value="NGN">NGN ₦</option><option value="USD">USD $</option><option value="EUR">EUR €</option><option value="GBP">GBP £</option></select></div>
                    <div class="col-md-3"><label class="form-label">Status</label><select id="f_status" class="form-select"><option value="draft">Draft</option><option value="sent">Sent</option><option value="paid">Paid</option></select></div>
                    <div class="col-md-6"><label class="form-label">Client name *</label><input id="f_client_name" class="form-control"></div>
                    <div class="col-md-6"><label class="form-label">Client email</label><input id="f_client_email" type="email" class="form-control"></div>
                    <div class="col-md-6"><label class="form-label">Issue date</label><input id="f_issued" type="date" class="form-control"></div>
                    <div class="col-md-6"><label class="form-label">Due date</label><input id="f_due" type="date" class="form-control"></div>
                </div>

                <h5 class="mb-2">Line items</h5>
                <div class="table-responsive">
                    <table class="table table-bordered align-middle" id="itemsTbl">
                        <thead class="bg-light">
                            <tr><th style="width:50%;">Description</th><th>Qty</th><th>Rate</th><th>Amount</th><th></th></tr>
                        </thead>
                        <tbody id="itemsBody"></tbody>
                    </table>
                </div>
                <button class="btn btn-soft-primary btn-sm mb-3" id="btnAddItem"><i class="ti ti-plus"></i> Add item</button>

                <div class="row justify-content-end">
                    <div class="col-md-4">
                        <div class="d-flex justify-content-between"><span>Subtotal</span><span id="subTotal">₦0</span></div>
                        <div class="d-flex justify-content-between align-items-center mt-1">
                            <span>Tax</span>
                            <input id="f_tax" type="number" class="form-control form-control-sm" value="0" style="width:120px;">
                        </div>
                        <hr class="my-2">
                        <div class="d-flex justify-content-between fw-bold fs-18"><span>Total</span><span id="grandTotal">₦0</span></div>
                    </div>
                </div>

                <div class="mt-3"><label class="form-label">Notes</label><textarea id="f_notes" class="form-control" rows="2"></textarea></div>

                <div class="mt-3 text-end">
                    <a href="/admin/invoices" class="btn btn-light">Cancel</a>
                    <button class="btn btn-primary" id="btnSave">Create invoice</button>
                </div>
            </div>
        </div>
    </div>
</div>

<%- contentFor('extra_javascript') %>
<%- include('./partials/admin-api-helper') %>
<script>
(function () {
    const F = (id) => document.getElementById(id);
    const symbols = { NGN: '₦', USD: '$', EUR: '€', GBP: '£' };
    function row(desc='', qty=1, rate=0) {
        const tr = document.createElement('tr');
        tr.innerHTML = '<td><input class="form-control form-control-sm i-desc" value="' + desc + '"></td>'
            + '<td><input type="number" class="form-control form-control-sm i-qty" value="' + qty + '" style="width:80px;"></td>'
            + '<td><input type="number" class="form-control form-control-sm i-rate" value="' + rate + '" style="width:120px;"></td>'
            + '<td class="i-amt fw-medium">0</td>'
            + '<td><button class="btn btn-sm btn-soft-danger i-del"><i class="ti ti-x"></i></button></td>';
        F('itemsBody').appendChild(tr);
        tr.querySelectorAll('input').forEach(i => i.addEventListener('input', recalc));
        tr.querySelector('.i-del').addEventListener('click', () => { tr.remove(); recalc(); });
        recalc();
    }
    function recalc() {
        const sym = symbols[F('f_currency').value] || '';
        let sub = 0;
        document.querySelectorAll('#itemsBody tr').forEach(tr => {
            const q = Number(tr.querySelector('.i-qty').value) || 0;
            const r = Number(tr.querySelector('.i-rate').value) || 0;
            const amt = q * r; sub += amt;
            tr.querySelector('.i-amt').textContent = sym + amt.toLocaleString();
        });
        const tax = Number(F('f_tax').value) || 0;
        F('subTotal').textContent = sym + sub.toLocaleString();
        F('grandTotal').textContent = sym + (sub + tax).toLocaleString();
    }
    F('btnAddItem').addEventListener('click', () => row());
    F('f_tax').addEventListener('input', recalc);
    F('f_currency').addEventListener('change', recalc);
    F('f_client').addEventListener('change', () => {
        const o = F('f_client').options[F('f_client').selectedIndex];
        if (F('f_client').value) { F('f_client_name').value = o.dataset.name || ''; F('f_client_email').value = o.dataset.email || ''; }
    });
    row('Service / consulting', 1, 0);

    F('btnSave').addEventListener('click', async () => {
        const items = [...document.querySelectorAll('#itemsBody tr')].map(tr => ({
            description: tr.querySelector('.i-desc').value.trim(),
            qty: Number(tr.querySelector('.i-qty').value) || 0,
            rate: Number(tr.querySelector('.i-rate').value) || 0,
        })).filter(it => it.description);
        const payload = {
            client_id: F('f_client').value || null, client_name: F('f_client_name').value.trim(), client_email: F('f_client_email').value.trim(),
            currency: F('f_currency').value, status: F('f_status').value, issued_date: F('f_issued').value || '', due_date: F('f_due').value || '',
            tax: Number(F('f_tax').value) || 0, notes: F('f_notes').value.trim(), items,
        };
        if (!payload.client_name) return AdminAPI.toast('Client name required', true);
        if (!items.length) return AdminAPI.toast('Add at least one line item', true);
        const r = await AdminAPI.post('/invoices', payload);
        if (r.ok) { AdminAPI.toast('Invoice created'); location.href = '/admin/invoice/' + r.data.id; } else AdminAPI.toast(r.message, true);
    });
})();
</script>
