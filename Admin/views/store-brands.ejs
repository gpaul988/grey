<%- contentFor('html_attribute') %>

<%- contentFor('content') %>

    <%- include('./partials/page-title', {title: 'Brands', subtitle: 'Store'}) %>

    <div class="row g-3">
        <div class="col-xl-4">
            <div class="card">
                <div class="card-header"><h5 class="card-title mb-0">Add Brand</h5></div>
                <div class="card-body">
                    <form method="POST" action="/admin/store/brands" enctype="multipart/form-data">
                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                        <div class="mb-3">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input type="text" name="name" class="form-control" required placeholder="e.g. Dell">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Logo</label>
                            <input type="file" name="logo" class="form-control" accept="image/*">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="description" class="form-control" rows="2"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100"><i class="ti ti-plus me-1"></i>Add Brand</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="card">
                <div class="card-header"><h5 class="card-title mb-0">All Brands (<%= brands.length %>)</h5></div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead class="table-light">
                                <tr><th>Logo</th><th>Name</th><th>Slug</th><th>Products</th><th>Actions</th></tr>
                            </thead>
                            <tbody>
                                <% brands.forEach(b => { %>
                                <tr>
                                    <td>
                                        <% if(b.logo) { %>
                                        <img src="<%= b.logo %>" style="width:40px;height:40px;object-fit:contain" class="rounded border bg-white p-1">
                                        <% } else { %>
                                        <div class="rounded bg-light d-flex align-items-center justify-content-center" style="width:40px;height:40px"><i class="ti ti-building-store text-muted"></i></div>
                                        <% } %>
                                    </td>
                                    <td><strong><%= b.name %></strong></td>
                                    <td><code><%= b.slug %></code></td>
                                    <td><span class="badge bg-info-subtle text-info"><%= b.product_count || 0 %></span></td>
                                    <td><button class="btn btn-sm btn-soft-danger btn-del-brand" data-id="<%= b.id %>" data-name="<%= b.name %>"><i class="ti ti-trash"></i></button></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

<%- contentFor('extra_javascript') %>
<script src="/vendor/sweetalert2/sweetalert2.min.js"></script>
<script>
document.querySelectorAll('.btn-del-brand').forEach(function(b){
  b.addEventListener('click', function(){
    var id=b.dataset.id, name=b.dataset.name;
    Swal.fire({ title:'Delete brand?', text:name, icon:'warning', showCancelButton:true, confirmButtonColor:'#d33' })
      .then(function(r){ if(r.isConfirmed) fetch('/admin/api/store/brands/'+id,{method:'DELETE'}).then(function(r){return r.json();}).then(function(d){ if(d.ok) location.reload(); else Swal.fire('Error', d.error||'Failed','error'); }); });
  });
});
</script>
