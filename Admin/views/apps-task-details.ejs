<%- contentFor('html_attribute') %>
<%- contentFor('extra_css') %>
<%- contentFor('content') %>

<% const pc = ticket.priority==='urgent'?'danger':(ticket.priority==='high'?'warning':(ticket.priority==='low'?'secondary':'info'));
   const sc = ticket.status==='open'?'danger':(ticket.status==='pending'?'warning':(ticket.status==='resolved'?'success':'secondary')); %>

<%- include('./partials/page-title', { title: 'Ticket #' + ticket.id, subtitle: 'Support' }) %>

<div class="row">
    <div class="col-xl-8">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <div>
                        <h4 class="mb-1"><%= ticket.subject %></h4>
                        <small class="text-muted">From <strong><%= ticket.requester %></strong> <%= ticket.requester_email ? '· ' + ticket.requester_email : '' %> · <%= timeAgo(ticket.created_at) %></small>
                    </div>
                    <div class="d-flex gap-1">
                        <span class="badge text-capitalize bg-<%= pc %>-subtle text-<%= pc %>"><%= ticket.priority %></span>
                        <span class="badge text-capitalize bg-<%= sc %>-subtle text-<%= sc %>" id="statusBadge"><%= ticket.status %></span>
                    </div>
                </div>
                <% if (ticket.body) { %>
                <div class="border rounded p-3 bg-light bg-opacity-50 mb-4"><%= ticket.body %></div>
                <% } %>

                <h5 class="mb-3">Conversation</h5>
                <div id="thread">
                    <% if (!messages.length) { %><p class="text-muted" id="emptyThread">No replies yet.</p><% } %>
                    <% messages.forEach((m) => { %>
                    <div class="d-flex mb-3 <%= m.is_staff ? 'flex-row-reverse text-end' : '' %>">
                        <div class="<%= m.is_staff ? 'ms-2' : 'me-2' %>">
                            <span class="avatar-sm"><span class="avatar-title bg-<%= m.is_staff ? 'primary' : 'secondary' %>-subtle text-<%= m.is_staff ? 'primary' : 'secondary' %> rounded-circle"><%= (m.author||'?').charAt(0) %></span></span>
                        </div>
                        <div>
                            <div class="p-2 px-3 rounded bg-<%= m.is_staff ? 'primary-subtle' : 'light' %> d-inline-block"><%= m.body %></div>
                            <div><small class="text-muted"><%= m.author %> · <%= timeAgo(m.created_at) %></small></div>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <div class="mt-3">
                    <textarea id="replyBody" class="form-control mb-2" rows="3" placeholder="Type your reply..."></textarea>
                    <button class="btn btn-primary" id="btnReply"><i class="ti ti-send"></i> Send reply</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0">Manage</h5></div>
            <div class="card-body">
                <label class="form-label">Status</label>
                <select id="selStatus" class="form-select mb-3">
                    <option value="open" <%= ticket.status==='open'?'selected':'' %>>Open</option>
                    <option value="pending" <%= ticket.status==='pending'?'selected':'' %>>Pending</option>
                    <option value="resolved" <%= ticket.status==='resolved'?'selected':'' %>>Resolved</option>
                    <option value="closed" <%= ticket.status==='closed'?'selected':'' %>>Closed</option>
                </select>
                <label class="form-label">Priority</label>
                <select id="selPriority" class="form-select mb-3">
                    <option value="low" <%= ticket.priority==='low'?'selected':'' %>>Low</option>
                    <option value="medium" <%= ticket.priority==='medium'?'selected':'' %>>Medium</option>
                    <option value="high" <%= ticket.priority==='high'?'selected':'' %>>High</option>
                    <option value="urgent" <%= ticket.priority==='urgent'?'selected':'' %>>Urgent</option>
                </select>
                <button class="btn btn-soft-primary w-100 mb-2" id="btnUpdate">Update ticket</button>
                <a href="/admin/tickets" class="btn btn-light w-100">Back to tickets</a>
            </div>
        </div>
    </div>
</div>

<%- contentFor('extra_javascript') %>
<%- include('./partials/admin-api-helper') %>
<script>
(function () {
    const id = <%= ticket.id %>;
    const F = (i) => document.getElementById(i);
    F('btnReply').addEventListener('click', async () => {
        const body = F('replyBody').value.trim();
        if (!body) return AdminAPI.toast('Reply cannot be empty', true);
        const r = await AdminAPI.post('/tickets/' + id + '/reply', { body });
        if (r.ok) { AdminAPI.toast('Reply sent'); location.reload(); } else AdminAPI.toast(r.message, true);
    });
    F('btnUpdate').addEventListener('click', async () => {
        const r = await AdminAPI.patch('/tickets/' + id, { status: F('selStatus').value, priority: F('selPriority').value });
        if (r.ok) { AdminAPI.toast('Ticket updated'); location.reload(); } else AdminAPI.toast(r.message, true);
    });
})();
</script>
