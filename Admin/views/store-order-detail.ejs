<%- contentFor('html_attribute') %>

<%- contentFor('content') %>

    <%- include('./partials/page-title', {title: 'Order #' + order.order_number, subtitle: 'Store / Orders'}) %>

    <% const addr = JSON.parse(order.shipping_address || '{}'); %>

    <div class="row g-3">
        <div class="col-xl-8">
            <!-- Order Items -->
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Order Items</h5>
                    <span class="badge bg-primary-subtle text-primary"><%= items.length %> item(s)</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead class="table-light">
                                <tr><th>Product</th><th>Qty</th><th>Unit Price</th><th>Total</th></tr>
                            </thead>
                            <tbody>
                                <% items.forEach(item => { %>
                                <tr>
                                    <td class="d-flex align-items-center gap-2">
                                        <% if(item.product_image) { %>
                                        <img src="<%= item.product_image %>" style="width:40px;height:40px;object-fit:cover" class="rounded">
                                        <% } %>
                                        <div>
                                            <strong><%= item.product_name %></strong>
                                            <% if(item.product_sku) { %><br><small class="text-muted">SKU: <%= item.product_sku %></small><% } %>
                                        </div>
                                    </td>
                                    <td><%= item.quantity %></td>
                                    <td><%- fmtMoney(item.unit_price) %></td>
                                    <td><strong><%- fmtMoney(item.total_price) %></strong></td>
                                </tr>
                                <% }) %>
                            </tbody>
                            <tfoot class="table-light">
                                <tr><td colspan="3" class="text-end">Subtotal</td><td><%- fmtMoney(order.subtotal) %></td></tr>
                                <tr><td colspan="3" class="text-end">Shipping</td><td><%- fmtMoney(order.shipping_fee) %></td></tr>
                                <% if(order.discount > 0) { %><tr><td colspan="3" class="text-end text-success">Discount</td><td class="text-success">-<%- fmtMoney(order.discount) %></td></tr><% } %>
                                <tr><td colspan="3" class="text-end fw-bold">Total</td><td><strong><%- fmtMoney(order.total) %></strong></td></tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Staff Notes -->
            <div class="card">
                <div class="card-header"><h5 class="card-title mb-0">Staff Notes</h5></div>
                <div class="card-body">
                    <form id="notesForm">
                        <textarea id="staffNotes" class="form-control mb-2" rows="3" placeholder="Internal notes..."><%= order.staff_notes || '' %></textarea>
                        <button type="submit" class="btn btn-sm btn-primary">Save Notes</button>
                    </form>
                    <% if(order.notes) { %>
                    <div class="mt-3 p-3 bg-light rounded">
                        <strong>Customer Note:</strong> <%= order.notes %>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <!-- Status Update -->
            <div class="card mb-3">
                <div class="card-header"><h5 class="card-title mb-0">Update Status</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Order Status</label>
                        <select id="orderStatus" class="form-select">
                            <% ['pending','confirmed','processing','shipped','delivered','cancelled','refunded'].forEach(s => { %>
                            <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Payment Status</label>
                        <select id="paymentStatus" class="form-select">
                            <% ['unpaid','pending','paid','failed','refunded'].forEach(s => { %>
                            <option value="<%= s %>" <%= order.payment_status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option>
                            <% }) %>
                        </select>
                    </div>
                    <button class="btn btn-primary w-100" onclick="updateStatus()">Update</button>
                    <% if(order.payment_status !== 'paid') { %>
                    <button class="btn btn-success w-100 mt-2" onclick="confirmPayment()"><i class="ti ti-check me-1"></i>Confirm Payment (Bank Transfer)</button>
                    <small class="text-muted d-block mt-1">Marks the order paid &amp; confirmed once the customer's transfer reflects.</small>
                    <% } %>
                </div>
            </div>

            <!-- Customer Info -->
            <div class="card mb-3">
                <div class="card-header"><h5 class="card-title mb-0">Customer</h5></div>
                <div class="card-body">
                    <% if(order.customer_type === 'guest') { %>
                    <p class="mb-1"><i class="ti ti-user me-2 text-muted"></i><strong><%= order.guest_name || 'N/A' %></strong></p>
                    <p class="mb-1"><i class="ti ti-mail me-2 text-muted"></i><%= order.guest_email || 'N/A' %></p>
                    <p class="mb-1"><i class="ti ti-phone me-2 text-muted"></i><%= order.guest_phone || 'N/A' %></p>
                    <span class="badge bg-secondary-subtle text-secondary">Guest Order</span>
                    <% } else { %>
                    <p class="mb-1"><strong><%= customer?.first_name %> <%= customer?.last_name %></strong></p>
                    <p class="mb-1"><i class="ti ti-mail me-2 text-muted"></i><%= customer?.email || 'N/A' %></p>
                    <p class="mb-1"><i class="ti ti-phone me-2 text-muted"></i><%= customer?.phone || 'N/A' %></p>
                    <a href="/admin/store/customers/<%= customer?.id %>" class="btn btn-sm btn-soft-info mt-2">View Profile</a>
                    <% } %>
                </div>
            </div>

            <!-- Shipping Address -->
            <div class="card mb-3">
                <div class="card-header"><h5 class="card-title mb-0">Shipping Address</h5></div>
                <div class="card-body">
                    <% if(addr.address) { %>
                    <p class="mb-1"><%= addr.address %></p>
                    <p class="mb-1"><%= [addr.city, addr.state].filter(Boolean).join(', ') %></p>
                    <p class="mb-0"><%= addr.country || 'Nigeria' %></p>
                    <% } else { %>
                    <p class="text-muted">No address provided</p>
                    <% } %>
                </div>
            </div>

            <!-- Payment Info -->
            <div class="card">
                <div class="card-header"><h5 class="card-title mb-0">Payment</h5></div>
                <div class="card-body">
                    <p class="mb-1"><strong>Method:</strong> <%= order.payment_method || 'Not set' %></p>
                    <p class="mb-1"><strong>Gateway:</strong> <%= order.payment_gateway || '—' %></p>
                    <p class="mb-0"><strong>Reference:</strong> <code><%= order.payment_ref || '—' %></code></p>
                </div>
            </div>
        </div>
    </div>

<%- contentFor('extra_javascript') %>
<script>
function updateStatus() {
    const status = document.getElementById('orderStatus').value;
    const payment_status = document.getElementById('paymentStatus').value;
    fetch('/admin/api/store/orders/<%= order.id %>/status', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ status, payment_status })
    }).then(r=>r.json()).then(d => {
        if(d.ok) { Swal.fire('Updated!','Order status updated.','success').then(()=>location.reload()); }
        else Swal.fire('Error', d.error, 'error');
    });
}
function confirmPayment() {
    Swal.fire({ title: 'Confirm payment?', text: 'This marks the order as paid and confirmed.', icon: 'question', showCancelButton: true, confirmButtonText: 'Yes, confirm' }).then(res => {
        if(!res.isConfirmed) return;
        fetch('/admin/api/store/orders/<%= order.id %>/confirm-payment', { method: 'POST', headers: {'Content-Type':'application/json'} })
            .then(r=>r.json()).then(d => {
                if(d.ok) Swal.fire('Confirmed!','Payment confirmed.','success').then(()=>location.reload());
                else Swal.fire('Error', d.error, 'error');
            });
    });
}
document.getElementById('notesForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const notes = document.getElementById('staffNotes').value;
    fetch('/admin/api/store/orders/<%= order.id %>/notes', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ notes })
    }).then(r=>r.json()).then(d => {
        if(d.ok) Swal.fire('Saved','Notes saved.','success');
        else Swal.fire('Error',d.error,'error');
    });
});
</script>
