<%- contentFor('html_attribute') %>
<%- contentFor('extra_css') %>
<%- contentFor('content') %>

<%- include('./partials/page-title', { title: title, subtitle: 'Billing' }) %>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h4 class="card-title mb-0">Invoices <span class="badge bg-primary-subtle text-primary ms-1"><%= invoices.length %></span></h4>
                <div class="d-flex gap-2">
                    <select id="statusFilter" class="form-select form-select-sm" style="width:auto;">
                        <option value="">All</option><option value="draft">Draft</option><option value="sent">Sent</option><option value="paid">Paid</option><option value="overdue">Overdue</option><option value="cancelled">Cancelled</option>
                    </select>
                    <a href="/admin/invoice-create" class="btn btn-sm btn-primary"><i class="ti ti-plus"></i> New Invoice</a>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-centered mb-0" id="tbl">
                    <thead class="bg-light bg-opacity-50">
                        <tr><th>Number</th><th>Client</th><th>Issued</th><th>Due</th><th>Total</th><th>Status</th><th class="text-end">Action</th></tr>
                    </thead>
                    <tbody>
                        <% if (!invoices.length) { %><tr><td colspan="7" class="text-center text-muted py-4">No invoices yet.</td></tr><% } %>
                        <% invoices.forEach((iv) => { const sc = iv.status==='paid'?'success':(iv.status==='overdue'?'danger':(iv.status==='sent'?'info':(iv.status==='cancelled'?'secondary':'warning'))); %>
                        <tr data-status="<%= iv.status %>">
                            <td><a href="/admin/invoice/<%= iv.id %>" class="fw-medium text-reset"><%= iv.number %></a></td>
                            <td><div><%= iv.client_name %></div><small class="text-muted"><%= iv.client_email || '' %></small></td>
                            <td class="text-muted fs-13"><%= iv.issued_date || '—' %></td>
                            <td class="text-muted fs-13"><%= iv.due_date || '—' %></td>
                            <td class="fw-medium"><%= fmtMoney(iv.total, iv.currency) %></td>
                            <td>
                                <select class="form-select form-select-sm sel-status text-capitalize" data-id="<%= iv.id %>" style="width:auto;">
                                    <% ['draft','sent','paid','overdue','cancelled'].forEach(s=>{ %><option value="<%= s %>" <%= iv.status===s?'selected':'' %>><%= s %></option><% }) %>
                                </select>
                            </td>
                            <td class="text-end">
                                <a href="/admin/invoice/<%= iv.id %>" class="btn btn-sm btn-soft-primary"><i class="ti ti-eye"></i></a>
                                <button class="btn btn-sm btn-soft-danger btn-del" data-id="<%= iv.id %>"><i class="ti ti-trash"></i></button>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- contentFor('extra_javascript') %>
<%- include('./partials/admin-api-helper') %>
<script>
(function () {
    document.querySelectorAll('.sel-status').forEach(s => s.addEventListener('change', async () => {
        const r = await AdminAPI.patch('/invoices/' + s.dataset.id, { status: s.value });
        if (r.ok) AdminAPI.toast('Status updated'); else AdminAPI.toast(r.message, true);
    }));
    document.querySelectorAll('.btn-del').forEach(b => b.addEventListener('click', async () => {
        if (!confirm('Delete this invoice?')) return;
        const r = await AdminAPI.del('/invoices/' + b.dataset.id);
        if (r.ok) { AdminAPI.toast('Deleted'); b.closest('tr').remove(); } else AdminAPI.toast(r.message, true);
    }));
    document.getElementById('statusFilter').addEventListener('change', (e) => {
        const v = e.target.value;
        document.querySelectorAll('#tbl tbody tr[data-status]').forEach(tr => tr.style.display = (!v || tr.dataset.status === v) ? '' : 'none');
    });
})();
</script>
