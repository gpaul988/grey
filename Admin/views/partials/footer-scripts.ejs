<script src="/js/vendor.min.js"></script>

<!-- App js -->
<script src="/js/app.js"></script>
<!-- Real-time admin updates via SSE -->
<script>
    (function () {
        'use strict';
        if (typeof EventSource === 'undefined') return;

        let es;
        let retryDelay = 3000;

        function connect() {
            es = new EventSource('/admin/events');

            es.addEventListener('connected', () => {
                retryDelay = 3000; // reset backoff on successful connect
            });

            // ── Stats refresh ──────────────────────────────────────────────────
            es.addEventListener('stats', (e) => {
                try {
                    const s = JSON.parse(e.data);
                    updateBadge('[data-badge="newSubmissions"]', s.newSubmissions);
                    updateBadge('[data-badge="openTickets"]', s.openTickets);
                    updateBadge('[data-badge="unreadConvos"]', s.unreadConvos);
                } catch { /* ignore parse errors */
                }
            });

            // ── New ticket: toast + page refresh if on tickets page ───────────
            es.addEventListener('ticket', (e) => {
                try {
                    const d = JSON.parse(e.data);
                    if (d.action === 'create') {
                        showToast('New ticket', `"${d.ticket?.subject || 'Support request'}" just came in.`, 'ti-ticket', 'warning');
                        if (location.pathname.includes('/tickets')) {
                            setTimeout(() => location.reload(), 1500);
                        }
                    }
                } catch { /* ignore */
                }
            });

            // ── New submission ─────────────────────────────────────────────────
            es.addEventListener('submission', (e) => {
                try {
                    const d = JSON.parse(e.data);
                    if (d.action === 'create') {
                        showToast('New submission', 'A new contact form submission arrived.', 'ti-mail', 'info');
                        if (location.pathname.includes('/submissions')) {
                            setTimeout(() => location.reload(), 1500);
                        }
                    }
                } catch { /* ignore */
                }
            });

            // ── New lead ───────────────────────────────────────────────────────
            es.addEventListener('lead', (e) => {
                try {
                    const d = JSON.parse(e.data);
                    if (d.action === 'create') {
                        showToast('New lead', `${d.lead?.name || 'Someone'} entered the pipeline.`, 'ti-target-arrow', 'success');
                        if (location.pathname.includes('/leads')) {
                            setTimeout(() => location.reload(), 1500);
                        }
                    }
                } catch { /* ignore */
                }
            });

            es.onerror = () => {
                es.close();
                // Exponential back-off: 3s → 6s → 12s → … capped at 60s
                setTimeout(connect, retryDelay = Math.min(retryDelay * 2, 60000));
            };
        }

        // ── Helpers ─────────────────────────────────────────────────────────────

        function updateBadge(selector, count) {
            document.querySelectorAll(selector).forEach(el => {
                el.textContent = count > 99 ? '99+' : (count || '');
                el.style.display = count > 0 ? '' : 'none';
            });
        }

        function showToast(title, message, icon, type) {
            // Use Bootstrap toast if available, otherwise fall back to console
            const toastContainer = document.getElementById('sse-toast-container');
            if (!toastContainer) return;
            const id = 'toast-' + Date.now();
            const colors = {warning: 'text-warning', info: 'text-info', success: 'text-success', danger: 'text-danger'};
            toastContainer.insertAdjacentHTML('beforeend', `
            <div id="${id}" class="toast align-items-center border-0 shadow" role="alert" aria-live="assertive">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <i class="ti ${icon} fs-18 ${colors[type] || ''}"></i>
                        <div><strong>${title}</strong><br><span class="fs-13 text-muted">${message}</span></div>
                    </div>
                    <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>`);
            const el = document.getElementById(id);
            const toast = new bootstrap.Toast(el, {delay: 6000});
            toast.show();
            el.addEventListener('hidden.bs.toast', () => el.remove());
        }

        connect();
    })();
</script>

