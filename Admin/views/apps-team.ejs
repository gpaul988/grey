<%- contentFor('html_attribute') %>
<%- contentFor('extra_css') %>
<%- contentFor('content') %>

<% const isAdmin = (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'superadmin')); %>

<%- include('./partials/page-title', { title: title, subtitle: 'Administration' }) %>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h4 class="card-title mb-0">Team Members <span class="badge bg-primary-subtle text-primary ms-1"><%= users.length %></span></h4>
                <% if (isAdmin) { %><button class="btn btn-sm btn-primary" id="btnNew"><i class="ti ti-plus"></i> Add Member</button><% } %>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-centered mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr><th>Name</th><th>Email</th><th>Role</th><th>Phone</th><th>Status</th><% if (isAdmin) { %><th class="text-end">Action</th><% } %></tr>
                    </thead>
                    <tbody>
                        <% users.forEach((u) => { %>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="avatar-sm"><span class="avatar-title bg-primary-subtle text-primary rounded-circle"><%= u.name.charAt(0) %></span></span>
                                    <span class="fw-medium"><%= u.name %></span>
                                </div>
                            </td>
                            <td><%= u.email %></td>
                            <% var roleColor = u.role==='superadmin'?'dark':(u.role==='admin'?'danger':(u.role==='manager'?'warning':'info')); %>
                            <td><span class="badge text-capitalize bg-<%= roleColor %>-subtle text-<%= roleColor %>"><%= u.role==='superadmin' ? 'Super Admin' : u.role %></span></td>
                            <td><%= u.phone || '—' %></td>
                            <td><span class="badge bg-<%= u.status==='active'?'success':'secondary' %>-subtle text-<%= u.status==='active'?'success':'secondary' %> text-capitalize"><%= u.status %></span></td>
                            <% if (isAdmin) { %>
                            <td class="text-end">
                                <% if (u.role !== 'admin' && u.role !== 'superadmin') { %>
                                <button class="btn btn-sm btn-soft-info btn-perms" data-id="<%= u.id %>" data-name="<%= u.name %>" data-role="<%= u.role %>" title="Permissions"><i class="ti ti-shield-lock"></i></button>
                                <% } %>
                                <button class="btn btn-sm btn-soft-primary btn-edit" data-id="<%= u.id %>" data-name="<%= u.name %>" data-email="<%= u.email %>" data-role="<%= u.role %>" data-phone="<%= u.phone||'' %>" data-status="<%= u.status %>"><i class="ti ti-edit"></i></button>
                                <% if (u.status !== 'active') { %>
                                <button class="btn btn-sm btn-soft-success btn-setup" data-id="<%= u.id %>" data-email="<%= u.email %>" title="Send set-password link"><i class="ti ti-mail-forward"></i></button>
                                <% } %>
                                <% if (u.role !== 'superadmin') { %>
                                <button class="btn btn-sm btn-soft-danger btn-del" data-id="<%= u.id %>"><i class="ti ti-trash"></i></button>
                                <% } %>
                            </td>
                            <% } %>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<% if (isAdmin) { %>
<div class="modal fade" id="uModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title" id="mTitle">Add Member</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <input type="hidden" id="f_id">
                <div class="mb-3"><label class="form-label">Name *</label><input id="f_name" class="form-control"></div>
                <div class="mb-3"><label class="form-label">Email *</label><input id="f_email" type="email" class="form-control"></div>
                <div class="mb-3"><label class="form-label">Phone</label><input id="f_phone" class="form-control"></div>
                <div class="row">
                    <div class="col-6 mb-3"><label class="form-label">Role</label><select id="f_role" class="form-select"><option value="staff">Staff</option><option value="manager">Manager</option><option value="admin">Admin</option><% if (typeof user !== 'undefined' && user && user.role === 'superadmin') { %><option value="superadmin">Super Admin</option><% } %></select></div>
                    <div class="col-6 mb-3"><label class="form-label">Status</label><select id="f_status" class="form-select"><option value="active">Active</option><option value="suspended">Suspended</option></select></div>
                </div>
                <div class="mb-3"><label class="form-label" id="pwLabel">Password *</label><input id="f_password" type="password" class="form-control" placeholder="Min 8 characters"></div>
            </div>
            <div class="modal-footer"><button class="btn btn-light" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" id="btnSave">Save</button></div>
        </div>
    </div>
</div>

<!-- Permissions modal -->
<div class="modal fade" id="permModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Permissions — <span id="pmName"></span></h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted fs-13">Toggle exactly what <span id="pmName2"></span> can access. Base role: <span id="pmRole" class="fw-semibold text-capitalize"></span>. Unchecked items are denied even if the role normally allows them.</p>
                <input type="hidden" id="pm_id">
                <div class="d-flex justify-content-end gap-2 mb-2">
                    <button type="button" class="btn btn-sm btn-light" id="pmSelectAll">Select all</button>
                    <button type="button" class="btn btn-sm btn-light" id="pmReset">Reset to role defaults</button>
                </div>
                <div class="row g-3" id="pmGroups"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="pmSave">Save permissions</button>
            </div>
        </div>
    </div>
</div>

<%- contentFor('extra_javascript') %>
<%- include('./partials/admin-api-helper') %>
<script id="permData" type="application/json"><%- JSON.stringify({ defs: permissionDefs, effective: effectivePerms }) %></script>
<script>
(function () {
    const modal = new bootstrap.Modal('#uModal');
    const F = (id) => document.getElementById(id);
    function open(d) {
        F('f_id').value = d.id || ''; F('mTitle').textContent = d.id ? 'Edit Member' : 'Add Member';
        F('f_name').value = d.name || ''; F('f_email').value = d.email || ''; F('f_phone').value = d.phone || '';
        F('f_role').value = d.role || 'staff'; F('f_status').value = d.status || 'active'; F('f_password').value = '';
        F('pwLabel').textContent = d.id ? 'New password (leave blank to keep)' : 'Password *';
        modal.show();
    }
    F('btnNew').addEventListener('click', () => open({}));
    document.querySelectorAll('.btn-edit').forEach(b => b.addEventListener('click', () => open(b.dataset)));
    F('btnSave').addEventListener('click', async () => {
        const id = F('f_id').value;
        const payload = { name: F('f_name').value.trim(), email: F('f_email').value.trim(), phone: F('f_phone').value.trim(), role: F('f_role').value, status: F('f_status').value };
        const pw = F('f_password').value;
        if (pw) payload.password = pw;
        if (!payload.name || !payload.email) return AdminAPI.toast('Name and email required', true);
        if (!id && !pw) return AdminAPI.toast('Password required for new member', true);
        const r = id ? await AdminAPI.patch('/users/' + id, payload) : await AdminAPI.post('/users', payload);
        if (r.ok) { AdminAPI.toast(r.message); location.reload(); } else AdminAPI.toast(r.message, true);
    });
    document.querySelectorAll('.btn-del').forEach(b => b.addEventListener('click', async () => {
        if (!confirm('Delete this member?')) return;
        const r = await AdminAPI.del('/users/' + b.dataset.id);
        if (r.ok) { AdminAPI.toast('Deleted'); b.closest('tr').remove(); } else AdminAPI.toast(r.message, true);
    }));

    /* ---------- Send set-password / verification link ---------- */
    document.querySelectorAll('.btn-setup').forEach(b => b.addEventListener('click', async () => {
        const email = b.dataset.email || 'this user';
        if (!confirm('Send a set-password / verification link to ' + email + '?')) return;
        b.disabled = true;
        const r = await AdminAPI.post('/users/' + b.dataset.id + '/send-setup-link');
        b.disabled = false;
        if (r.ok) {
            AdminAPI.toast(r.message);
            // When SMTP isn't configured the link is returned so it can be shared manually.
            if (r.data && r.data.link) {
                window.prompt('Copy this set-password link and send it to ' + email + ':', r.data.link);
            }
        } else AdminAPI.toast(r.message, true);
    }));

    /* ---------- Permissions ---------- */
    const PERM = JSON.parse(document.getElementById('permData').textContent || '{}');
    const DEFS = PERM.defs || [];
    const EFFECTIVE = PERM.effective || {};
    const ROLE_DEFAULTS = {
        manager: DEFS.map(d => d.key).filter(k => k !== 'team.manage' && k !== 'settings.manage'),
        staff: ['dashboard.view','submissions.view','leads.view','clients.view','projects.view','projects.manage','briefs.view','tickets.view','tickets.manage','invoices.view','messages.view','messages.send','blog.view','casestudies.view'],
    };
    const permModal = document.getElementById('permModal') ? new bootstrap.Modal('#permModal') : null;

    function renderGroups(checked) {
        const groups = {};
        DEFS.forEach(d => { (groups[d.group] = groups[d.group] || []).push(d); });
        const html = Object.entries(groups).map(([g, items]) => `
            <div class="col-md-6">
                <h6 class="text-uppercase fs-12 text-muted mb-2">${g}</h6>
                ${items.map(it => `
                    <div class="form-check mb-1">
                        <input class="form-check-input pm-cb" type="checkbox" id="pm_${it.key}" data-key="${it.key}" ${checked.has(it.key) ? 'checked' : ''}>
                        <label class="form-check-label" for="pm_${it.key}">${it.label}</label>
                    </div>`).join('')}
            </div>`).join('');
        document.getElementById('pmGroups').innerHTML = html;
    }

    function openPerms(d) {
        document.getElementById('pm_id').value = d.id;
        document.getElementById('pmName').textContent = d.name;
        document.getElementById('pmName2').textContent = d.name;
        document.getElementById('pmRole').textContent = d.role;
        renderGroups(new Set(EFFECTIVE[d.id] || []));
        permModal && permModal.show();
    }

    document.querySelectorAll('.btn-perms').forEach(b => b.addEventListener('click', () => openPerms(b.dataset)));

    const pmSelectAll = document.getElementById('pmSelectAll');
    pmSelectAll && pmSelectAll.addEventListener('click', () => document.querySelectorAll('.pm-cb').forEach(c => c.checked = true));
    const pmReset = document.getElementById('pmReset');
    pmReset && pmReset.addEventListener('click', () => {
        const role = document.getElementById('pmRole').textContent;
        const defaults = new Set(ROLE_DEFAULTS[role] || []);
        document.querySelectorAll('.pm-cb').forEach(c => c.checked = defaults.has(c.dataset.key));
    });
    const pmSave = document.getElementById('pmSave');
    pmSave && pmSave.addEventListener('click', async () => {
        const id = document.getElementById('pm_id').value;
        const permissions = {};
        document.querySelectorAll('.pm-cb').forEach(c => { permissions[c.dataset.key] = c.checked; });
        const r = await AdminAPI.patch('/users/' + id + '/permissions', { permissions });
        if (r.ok) { AdminAPI.toast('Permissions updated'); EFFECTIVE[id] = Object.keys(permissions).filter(k => permissions[k]); permModal && permModal.hide(); }
        else AdminAPI.toast(r.message, true);
    });
})();
</script>
<% } %>
