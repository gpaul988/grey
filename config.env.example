# ─── Grey InfoTech — Environment Variables ───────────────────────────────────
# Copy to .env and fill in. In PRODUCTION the app refuses to start without
# strong (>=16 char) secrets for SESSION_SECRET / CSRF_SECRET.

NODE_ENV=production
PORT=3000

# ── Security (REQUIRED in production) ──
SESSION_SECRET=
CSRF_SECRET=
# Optional: separate secret for customer/store sessions (falls back to SESSION_SECRET)
CUSTOMER_SESSION_SECRET=

# ── AI assistant (OPTIONAL) ──
# If unset, the AI chatbot uses a built-in local knowledge-base answerer (free,
# no external calls). Set these to enable streamed LLM answers.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── SMTP (contact / tickets email) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Store payment gateways (set the ones you use) ──
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
