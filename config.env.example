# ===========================================================================
# Grey InfoTech — environment configuration template
# Copy to `config.env` on the server and fill in real values.
# config.env is gitignored and must NEVER be committed.
# On cPanel you can instead set these in the "Setup Node.js App" → Environment
# Variables UI (recommended for secrets).
# ===========================================================================

# --- Core ---
NODE_ENV=production
# Passenger sets PORT automatically on cPanel — leave it unset there.
# PORT=3000

# Public origins used for email links and payment callbacks/webhooks.
APP_URL=https://greyinfotech.com.ng
FRONTEND_BASE_URL=https://greyinfotech.com.ng
BACKEND_BASE_URL=https://greyinfotech.com.ng

# Signs admin session cookies. Generate a long random value:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- SMTP (verification / set-password / invite emails) ---
SMTP_HOST=greyinfotech.com.ng
SMTP_PORT=465
SMTP_USER=hello@greyinfotech.com.ng
SMTP_PASS=your-mailbox-password
SMTP_FROM=Grey InfoTech <hello@greyinfotech.com.ng>

# --- Database (optional). Defaults to Admin/data/grey.db inside the app.
# Point this OUTSIDE the deploy folder so re-deploys never wipe live data.
# DB_PATH=/home/CPANELUSER/grey-data/grey.db

# --- Initial seed admin (only used the first time the DB is created) ---
# SEED_ADMIN_EMAIL=hello@greyinfotech.com.ng
# SEED_ADMIN_PASSWORD=GreyAdmin@2026

# NOTE: Payment gateway keys (Paystack / Flutterwave / Monnify) are NOT set here.
# The superadmin configures and toggles them from the admin dashboard (stored in DB).
